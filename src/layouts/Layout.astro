---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Pegaso System - Desarrollo de Software Comercial y Soluciones Web Corporativas de Alto Rendimiento." } = Astro.props;
---

<!doctype html>
<html lang="es" class="js">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=Inter:wght@300;400;500;600;700;800;900&family=Montserrat:wght@300;400;700;800;900&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
		
		<!-- GSAP, ScrollTrigger and ScrollToPlugin CDN -->
		<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
		<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
		<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollToPlugin.min.js"></script>
		
		<title>{title}</title>
		
		<style>
			/* Prevenir parpadeo de carga (FOUC) en elementos del Hero animado */
			.js #inicio h2,
			.js #inicio h1 span,
			.js #hero-desc,
			.js #hero-buttons {
				opacity: 0;
			}
		</style>
		
		<noscript>
			<style>
				#inicio h2,
				#inicio h1 span,
				#hero-desc,
				#hero-buttons,
				.animate-on-scroll {
					opacity: 1 !important;
				}
			</style>
		</noscript>
	</head>
	<body class="bg-cosmos-dark text-white min-h-screen relative font-sans overflow-x-hidden antialiased">
		<div class="fixed inset-0 bg-stars -z-20"></div>
		
		<!-- Shooting Stars Overlay -->
		<div class="fixed inset-0 overflow-hidden pointer-events-none -z-10">
			<div class="shooting-star" style="top: 10%; left: -10%; animation-delay: 0s;"></div>
			<div class="shooting-star" style="top: 30%; left: -20%; animation-delay: 2s; opacity: 0.6;"></div>
			<div class="shooting-star" style="top: 50%; left: -5%; animation-delay: 1.5s; opacity: 0.8;"></div>
			<div class="shooting-star" style="top: 70%; left: -15%; animation-delay: 4s;"></div>
			<div class="shooting-star" style="top: -10%; left: 40%; animation-delay: 3s; opacity: 0.7;"></div>
			<div class="shooting-star" style="top: -5%; left: 80%; animation-delay: 1s;"></div>
		</div>
		
		<div class="fixed inset-0 bg-gradient-to-b from-transparent to-cosmos-dark/90 -z-10"></div>
		
		<slot />
		
		<script>
			// Animaciones avanzadas y fluidas con GSAP
			const initGSAP = () => {
				// 1. Registrar el plugin ScrollTrigger y ScrollToPlugin
				// @ts-ignore
				gsap.registerPlugin(ScrollTrigger, ScrollToPlugin);

				// 2. Prevenir parpadeo inicial (FOUC): mostrar elementos controlados por JS e inicializar opacidades de carga
				// @ts-ignore
				gsap.set('.animate-on-scroll', { opacity: 1 });
				// @ts-ignore
				gsap.set(['#inicio h2', '#inicio h1 span', '#hero-desc', '#hero-buttons'], { opacity: 0 });

				// 3. Efecto de luz Spotlight en las tarjetas Glass (Ligero e interactivo)
				const cards = document.querySelectorAll('.glass-card');
				cards.forEach(card => {
					const htmlCard = card as HTMLElement;
					htmlCard.addEventListener('mousemove', e => {
						const rect = htmlCard.getBoundingClientRect();
						const x = e.clientX - rect.left;
						const y = e.clientY - rect.top;
						htmlCard.style.setProperty('--mouse-x', `${x}px`);
						htmlCard.style.setProperty('--mouse-y', `${y}px`);
					});
				});

				// 4. Animación del Hero en la carga inicial (Flujo secuencial correcto)
				// @ts-ignore
				const heroTimeline = gsap.timeline();
				heroTimeline
					.fromTo('#inicio h2', { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' })
					.fromTo('#inicio h1 span', { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 0.8, stagger: 0.15, ease: 'power3.out' }, '-=0.3')
					.fromTo('#hero-desc', { opacity: 0, y: 25 }, { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' }, '-=0.4')
					.fromTo('#hero-buttons', { opacity: 0, y: 15 }, { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' }, '-=0.3');

				// 5. Efecto Parallax en el contenido del Hero (Vinculado al scroll, fluido a 60 FPS)
				// @ts-ignore
				gsap.to('#inicio .text-center', {
					yPercent: 15,
					ease: 'none',
					scrollTrigger: {
						trigger: '#inicio',
						start: 'top top',
						end: 'bottom top',
						scrub: true
					}
				});

				// 5b. Desplazamiento suave global de enlaces locales para evitar lags (Intercepción de clicks)
				const hashLinks = document.querySelectorAll('a[href^="#"]');
				hashLinks.forEach(link => {
					link.addEventListener('click', (e) => {
						const targetId = link.getAttribute('href');
						if (!targetId || targetId === '#') return;
						const targetElement = document.querySelector(targetId);
						if (targetElement) {
							e.preventDefault();
							const navbar = document.getElementById('navbar');
							const offset = navbar ? navbar.offsetHeight : 0;
							
							// @ts-ignore
							gsap.to(window, {
								duration: 0.9,
								scrollTo: { y: targetElement, offsetY: offset },
								ease: 'power2.out',
								overwrite: 'auto'
							});
						}
					});
				});

				// 6. Títulos de secciones con revelado progresivo (Excluyendo Hero para evitar conflictos de animación)
				const sectionHeaders = document.querySelectorAll('section:not(#inicio) .text-center h2, section:not(#inicio) .text-center h3, section:not(#inicio) .text-center div.w-16');
				sectionHeaders.forEach(header => {
					// @ts-ignore
					gsap.from(header, {
						opacity: 0,
						y: 30,
						duration: 1,
						ease: 'power3.out',
						scrollTrigger: {
							trigger: header,
							start: 'top 85%',
							toggleActions: 'play none none none'
						}
					});
				});

				// 7. Sección de Servicios (Entradas asimétricas / Secuenciales)
				const serviceRows = document.querySelectorAll('#servicios .space-y-32 > div');
				// @ts-ignore
				const mm = gsap.matchMedia();

				// Móvil: Animación secuencial (Título/Marca de agua primero, luego Tarjeta)
				mm.add("(max-width: 767px)", () => {
					serviceRows.forEach(row => {
						const card = row.querySelector('.glass-card');
						const textLabel = row.querySelector('.select-none');
						
						// @ts-ignore
						const tl = gsap.timeline({
							scrollTrigger: {
								trigger: row,
								start: 'top 85%',
								toggleActions: 'play none none none'
							}
						});

						if (textLabel) {
							tl.fromTo(textLabel,
								{ opacity: 0, y: 15, scale: 0.95 },
								{ opacity: 1, y: 0, scale: 1, duration: 0.7, ease: 'power2.out' }
							);
						}

						if (card) {
							tl.fromTo(card,
								{ opacity: 0, y: 25 },
								{ opacity: 1, y: 0, duration: 0.8, ease: 'power3.out' },
								'-=0.3'
							);
						}
					});
				});

				// Escritorio: Animación paralela original
				mm.add("(min-width: 768px)", () => {
					serviceRows.forEach(row => {
						const card = row.querySelector('.glass-card');
						const textLabel = row.querySelector('.select-none');
						
						if (card) {
							const isLeft = row.children[0].contains(card);
							// @ts-ignore
							gsap.from(card, {
								opacity: 0,
								x: isLeft ? -80 : 80,
								duration: 1.2,
								ease: 'power3.out',
								scrollTrigger: {
									trigger: row,
									start: 'top 75%',
									toggleActions: 'play none none none'
								}
							});
						}

						if (textLabel) {
							// @ts-ignore
							gsap.from(textLabel, {
								opacity: 0,
								scale: 0.9,
								duration: 1.5,
								ease: 'power2.out',
								scrollTrigger: {
									trigger: row,
									start: 'top 80%',
									toggleActions: 'play none none none'
								}
							});
						}
					});
				});

				// 8. Sección de Tecnología (Features)
				const techPillars = document.querySelectorAll('#tecnologia .grid > .glass-card');
				if (techPillars.length > 0) {
					// @ts-ignore
					gsap.from(techPillars, {
						opacity: 0,
						y: 40,
						scale: 0.95,
						stagger: 0.15,
						duration: 1,
						ease: 'power3.out',
						scrollTrigger: {
							trigger: '#tecnologia',
							start: 'top 70%',
							toggleActions: 'play none none none'
						}
					});
				}

				// 9. Sección de Precios (Planos de Solución)
				const pricingCards = document.querySelectorAll('#paquetes .glass-card');
				if (pricingCards.length > 0) {
					// @ts-ignore
					gsap.from(pricingCards, {
						opacity: 0,
						y: 60,
						scale: 0.95,
						stagger: 0.2,
						duration: 1,
						ease: 'power3.out',
						scrollTrigger: {
							trigger: '#paquetes',
							start: 'top 70%',
							toggleActions: 'play none none none'
						}
					});
				}

				// 10. Sección de Equipo
				const teamCards = document.querySelectorAll('#equipo .group');
				if (teamCards.length > 0) {
					// @ts-ignore
					gsap.from(teamCards, {
						opacity: 0,
						y: 50,
						stagger: 0.2,
						duration: 1,
						ease: 'power3.out',
						scrollTrigger: {
							trigger: '#equipo',
							start: 'top 70%',
							toggleActions: 'play none none none'
						}
					});
				}
			};

			// Inicialización robusta para evitar retrasos de carga
			if (document.readyState === "loading") {
				document.addEventListener("DOMContentLoaded", initGSAP);
			} else {
				initGSAP();
			}
		</script>
		
		<!-- Floating WhatsApp Widget -->
		<a href="https://wa.me/59179786916?text=Hola%20Pegaso%20System!%20Me%20gustar%C3%ADa%20realizar%20una%20consulta." target="_blank" rel="noopener noreferrer" class="fixed bottom-6 right-6 z-50 w-14 h-14 bg-[#25D366] rounded-full flex items-center justify-center shadow-[0_0_15px_rgba(37,211,102,0.4)] hover:shadow-[0_0_25px_rgba(37,211,102,0.7)] hover:scale-110 active:scale-95 transition-all duration-300 group cursor-pointer" aria-label="Chat on WhatsApp">
			<span class="absolute inset-0 rounded-full bg-[#25D366] whatsapp-pulse z-0 pointer-events-none"></span>
			<svg class="w-7 h-7 text-white fill-current relative z-10 transition-transform duration-300 group-hover:rotate-12" viewBox="0 0 24 24">
				<path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.513 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.625 1.449 5.4 0 9.794-4.392 9.797-9.793.002-2.617-1.015-5.078-2.862-6.928C16.36 1.953 13.9.936 11.895.936c-5.4 0-9.8 4.394-9.803 9.797-.001 1.905.5 3.758 1.45 5.367L2.5 22.148l6.147-1.614zM16.91 14.887c-.287-.143-1.697-.837-1.959-.933-.263-.097-.455-.145-.647.143-.19.288-.739.933-.906 1.123-.167.19-.335.21-.622.068-2.822-1.41-4.086-2.584-4.808-3.824-.188-.324-.019-.501.124-.643.13-.127.287-.335.43-.502.144-.167.191-.287.287-.478.096-.19.048-.36-.024-.503-.072-.143-.647-1.56-.887-2.136-.233-.56-.47-.482-.647-.49-.168-.008-.36-.01-.55-.01-.19 0-.503.07-.766.36-.263.288-1.006.984-1.006 2.402 0 1.417 1.03 2.787 1.173 2.977.143.19 2.027 3.1 4.91 4.34.686.295 1.22.47 1.636.602.69.219 1.317.188 1.815.114.553-.083 1.697-.693 1.937-1.362.24-.669.24-1.243.167-1.362-.072-.119-.263-.167-.55-.309z"/>
			</svg>
		</a>
	</body>
</html>

<style is:global>
	@keyframes whatsapp-ripple {
		0% {
			transform: scale(0.95);
			opacity: 0.5;
		}
		50% {
			transform: scale(1.3);
			opacity: 0.2;
		}
		100% {
			transform: scale(1.6);
			opacity: 0;
		}
	}
	.whatsapp-pulse {
		animation: whatsapp-ripple 2s infinite ease-out;
	}
</style>
