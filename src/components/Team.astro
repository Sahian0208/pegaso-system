---
---
<section id="equipo" class="py-[6rem] relative overflow-hidden bg-cosmos-light border-t border-gray-800">
  <div class="max-w-[80rem] mx-auto px-[1rem] sm:px-[1.5rem] lg:px-[2rem] relative z-10">
    <div class="animate-on-scroll fade-in-up text-center max-w-[48rem] mx-auto mb-[5rem]">
      <h2 class="text-gold-deep text-[0.75rem] font-bold tracking-[0.3em] uppercase mb-[1rem] border-b border-gray-700 pb-[0.5rem] inline-block text-glow">Liderazgo Ejecutivo</h2>
      <h3 class="text-[1.875rem] md:text-[3rem] font-normal font-heading mb-[1.5rem] text-white tracking-wide">Nuestros <span class="italic text-gold-bright">Líderes</span></h3>
      <p class="text-gray-400 text-[1.125rem] font-light">
        Ayudamos a las organizaciones a ordenar, controlar y crecer mediante tecnología, Business Intelligence e Inteligencia Artificial.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-[2rem] max-w-[80rem] mx-auto justify-items-center">
      
      <!-- Marco Daza Uriona - Negocios -->
      <div class="animate-on-scroll fade-in-up flex flex-col items-center group w-full">
        <div class="w-[11rem] h-[14rem] overflow-hidden mb-[2rem] relative border border-gray-800 bg-cosmos-dark/50 flex items-center justify-center shadow-[0_0_20px_rgba(148,163,184,0.05)] rounded-lg group-hover:border-gold-deep/30 group-hover:shadow-[0_0_30px_rgba(148,163,184,0.15)] transition-all duration-500">
          <div class="absolute inset-0 opacity-20 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:14px_24px] pointer-events-none"></div>
          <div class="absolute w-[6rem] h-[6rem] rounded-full bg-gold-bright/5 blur-xl pointer-events-none"></div>
          
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" class="w-[5rem] h-[5rem] text-gold-deep group-hover:text-gold-bright group-hover:scale-110 transition-all duration-500 pointer-events-none">
            <path d="M12 2a4 4 0 0 0-4 4v2a4 4 0 0 0 8 0V6a4 4 0 0 0-4-4z" />
            <path d="M6 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2" />
            <path d="M12 10.5v3M10.5 12h3" stroke-width="1.5" />
            <circle cx="12" cy="12" r="3.5" stroke-dasharray="2 2" />
            <polygon points="12,7 13.5,10.5 17,12 13.5,13.5 12,17 10.5,13.5 7,12 10.5,10.5" stroke="currentColor" stroke-width="1" class="opacity-50 group-hover:opacity-100 transition-opacity" />
          </svg>
        </div>
        <h3 class="text-[1.25rem] font-normal text-white font-heading mb-[0.5rem] text-glow text-center">Ing. Marco Daza Uriona</h3>
        <p class="text-gold-bright text-[0.5625rem] uppercase tracking-[0.2em] font-bold mb-[1rem] text-center">Negocios & Estrategia</p>
        <p class="text-gray-400 text-[0.75rem] text-center font-light leading-relaxed max-w-[13.75rem]">
          Visión comercial y crecimiento estratégico. Lidera la estructuración de soluciones tecnológicas viables para grandes organizaciones.
        </p>
      </div>

      <!-- Rodrigo Martinez - Sistemas -->
      <div class="animate-on-scroll fade-in-up flex flex-col items-center group mt-0 lg:mt-[3rem] w-full" style="transition-delay: 150ms;">
        <div class="w-[11rem] h-[14rem] overflow-hidden mb-[2rem] relative border border-gray-800 bg-cosmos-dark/50 flex items-center justify-center shadow-[0_0_20px_rgba(148,163,184,0.05)] rounded-lg group-hover:border-cosmos-blue/30 group-hover:shadow-[0_0_30px_rgba(59,130,246,0.15)] transition-all duration-500">
          <div class="absolute inset-0 opacity-20 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:14px_24px] pointer-events-none"></div>
          <div class="absolute w-[6rem] h-[6rem] rounded-full bg-cosmos-blue/5 blur-xl pointer-events-none"></div>
          
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" class="w-[5rem] h-[5rem] text-cosmos-blue group-hover:text-blue-400 group-hover:scale-110 transition-all duration-500 pointer-events-none">
            <path d="M12 2a4 4 0 0 0-4 4v2a4 4 0 0 0 8 0V6a4 4 0 0 0-4-4z" />
            <path d="M6 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2" />
            <circle cx="12" cy="7" r="1.5" fill="currentColor" />
            <circle cx="16" cy="11" r="1" fill="currentColor" />
            <circle cx="8" cy="11" r="1" fill="currentColor" />
            <line x1="12" y1="7" x2="16" y2="11" stroke-width="0.8" />
            <line x1="12" y1="7" x2="8" y2="11" stroke-width="0.8" />
            <line x1="8" y1="11" x2="16" y2="11" stroke-width="0.8" stroke-dasharray="1 1" />
            <path d="M12 15v3" />
            <circle cx="12" cy="19" r="1.5" stroke-width="1.5" />
          </svg>
        </div>
        <h3 class="text-[1.25rem] font-normal text-white font-heading mb-[0.5rem] text-glow text-center">Ing. Rodrigo Martinez</h3>
        <p class="text-cosmos-blue text-[0.5625rem] uppercase tracking-[0.2em] font-bold mb-[1rem] text-center">Arquitectura de Sistemas</p>
        <p class="text-gray-400 text-[0.75rem] text-center font-light leading-relaxed max-w-[13.75rem]">
          Diseño de infraestructuras y ecosistemas digitales redundantes. Garantiza la estabilidad, despliegue y continuidad operativa.
        </p>
      </div>

      <!-- Herbert Bustamante - Backend -->
      <div class="animate-on-scroll fade-in-up flex flex-col items-center group w-full" style="transition-delay: 300ms;">
        <div class="w-[11rem] h-[14rem] overflow-hidden mb-[2rem] relative border border-gray-800 bg-cosmos-dark/50 flex items-center justify-center shadow-[0_0_20px_rgba(148,163,184,0.05)] rounded-lg group-hover:border-cosmos-red/30 group-hover:shadow-[0_0_30px_rgba(96,165,250,0.15)] transition-all duration-500">
          <div class="absolute inset-0 opacity-20 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:14px_24px] pointer-events-none"></div>
          <div class="absolute w-[6rem] h-[6rem] rounded-full bg-cosmos-red/5 blur-xl pointer-events-none"></div>
          
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" class="w-[5rem] h-[5rem] text-cosmos-red group-hover:text-blue-300 group-hover:scale-110 transition-all duration-500 pointer-events-none">
            <path d="M12 2a4 4 0 0 0-4 4v2a4 4 0 0 0 8 0V6a4 4 0 0 0-4-4z" />
            <path d="M6 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2" />
            <path d="M5 8.5 L2.5 11 L5 13.5" stroke-width="1.5" />
            <path d="M19 8.5 L21.5 11 L19 13.5" stroke-width="1.5" />
            <path d="M9 15h6M9 17.5h6" stroke-width="1.5" />
          </svg>
        </div>
        <h3 class="text-[1.25rem] font-normal text-white font-heading mb-[0.5rem] text-glow text-center">Ing. Herbert Bustamante</h3>
        <p class="text-cosmos-red text-[0.5625rem] uppercase tracking-[0.2em] font-bold mb-[1rem] text-center">Desarrollo Backend Neto</p>
        <p class="text-gray-400 text-[0.75rem] text-center font-light leading-relaxed max-w-[13.75rem]">
          Desarrollo de algoritmos complejos, procesamiento de datos de alta escala y programación pura de código backend neto.
        </p>
      </div>

      <!-- Sahian Marine Sanchez - Frontend -->
      <div class="animate-on-scroll fade-in-up flex flex-col items-center group mt-0 lg:mt-[3rem] w-full" style="transition-delay: 450ms;">
        <div class="w-[11rem] h-[14rem] overflow-hidden mb-[2rem] relative border border-gray-800 bg-cosmos-dark/50 flex items-center justify-center shadow-[0_0_20px_rgba(148,163,184,0.05)] rounded-lg group-hover:border-purple-400/30 group-hover:shadow-[0_0_30px_rgba(192,132,252,0.15)] transition-all duration-500">
          <div class="absolute inset-0 opacity-20 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:14px_24px] pointer-events-none"></div>
          <div class="absolute w-[6rem] h-[6rem] rounded-full bg-purple-400/5 blur-xl pointer-events-none"></div>
          
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" class="w-[5rem] h-[5rem] text-purple-400 group-hover:text-purple-300 group-hover:scale-110 transition-all duration-500 pointer-events-none">
            <path d="M12 2a4 4 0 0 0-4 4v2a4 4 0 0 0 8 0V6a4 4 0 0 0-4-4z" />
            <path d="M6 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2" />
            <circle cx="12" cy="7" r="1" fill="currentColor" />
            <path d="M12 10.5v1.5M10.5 12h3" />
            <path d="M18 6.5 L19.5 8 L18 9.5 L16.5 8 Z" fill="currentColor" stroke="none" />
            <rect x="9" y="15" width="6" height="4" rx="0.5" stroke-width="1" />
            <line x1="12" y1="15" x2="12" y2="19" />
          </svg>
        </div>
        <h3 class="text-[1.25rem] font-normal text-white font-heading mb-[0.5rem] text-glow text-center">Ing. Sahian Marine Sanchez</h3>
        <p class="text-purple-400 text-[0.5625rem] uppercase tracking-[0.2em] font-bold mb-[1rem] text-center">Diseño & Frontend</p>
        <p class="text-gray-400 text-[0.75rem] text-center font-light leading-relaxed max-w-[13.75rem]">
          Diseño de interfaces dinámicas y experiencias interactivas premium. Especialista en micro-animaciones y layouts responsivos de alta gama.
        </p>
      </div>

    </div>
  </div>
</section>
