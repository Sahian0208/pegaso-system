---
interface Props {
  title: string;
  description: string;
  iconType: 'tauro' | 'fenix' | 'aries' | 'andromeda' | 'pegaso';
}

const { title, description, iconType } = Astro.props;

// Neon blue styles instead of individual colors
const config = {
  color: 'text-gold-bright',
  bg: 'bg-transparent',
  border: 'border-gold-bright/30',
  hoverBorder: 'group-hover:border-gold-bright',
  shadow: 'group-hover:shadow-[0_0_15px_rgba(0,229,255,0.4)]',
};
---

<div class={`flex flex-col items-center text-center p-6 border ${config.border} rounded-xl transition-all duration-300 ${config.hoverBorder} ${config.shadow} bg-cosmos-dark/40 backdrop-blur-sm group cursor-pointer`}>
  
  <div class={`w-12 h-12 flex items-center justify-center mb-4 ${config.color} group-hover:scale-110 group-hover:text-white transition-all duration-300`}>
    <slot name="icon" />
  </div>
  
  <h3 class="text-lg font-bold font-heading mb-2 text-white group-hover:text-gold-bright transition-colors">{title}</h3>
  
  <div class="mt-2 mb-4 w-8 h-px bg-gold-deep/50 group-hover:bg-gold-bright transition-colors"></div>
  
  <span class={`text-xs uppercase tracking-widest text-gold-deep group-hover:text-gold-bright transition-colors font-semibold`}>
    <slot name="constellation-name" />
  </span>
  
  <!-- We'll hide the long description on the grid to match the image style, showing it on hover or keeping it minimal -->
  <p class="text-gray-400 text-sm mt-4 leading-relaxed opacity-0 max-h-0 overflow-hidden group-hover:opacity-100 group-hover:max-h-40 transition-all duration-500">
    {description}
  </p>
</div>
