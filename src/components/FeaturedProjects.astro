---
---
<section class="py-10 bg-[#0e1220] border-b border-gray-900 relative z-30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8 md:gap-12">
      
      <!-- Label -->
      <div class="flex-shrink-0 text-center md:text-left">
        <span class="text-xs font-semibold uppercase tracking-[0.3em] text-gray-500 font-montserrat">
          Proyectos Destacados
        </span>
      </div>
      
      <!-- Logos Container -->
      <div class="flex flex-wrap items-center justify-center gap-10 sm:gap-16 md:gap-20 flex-grow">
        
        <!-- Chocolates Taboada (Día de la Madre) -->
        <a 
          href="https://dia-de-la-madre-taboada.vercel.app/" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="group transition-all duration-300 transform hover:scale-110 flex items-center justify-center"
        >
          <img 
            src="/logo-taboada-gold.png" 
            alt="Chocolates Taboada - Madre" 
            class="h-10 sm:h-12 w-auto object-contain opacity-70 group-hover:opacity-100 filter brightness-110 drop-shadow-[0_0_8px_rgba(212,175,55,0.2)] group-hover:drop-shadow-[0_0_15px_rgba(212,175,55,0.5)] transition-all duration-300" 
          />
        </a>

        <!-- Chocolates Taboada (Fexco) -->
        <a 
          href="https://taboada-fexco.vercel.app" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="group transition-all duration-300 transform hover:scale-110 flex items-center justify-center"
        >
          <img 
            src="/logo-taboada-brown.png" 
            alt="Chocolates Taboada - Fexco" 
            class="h-10 sm:h-12 w-auto object-contain opacity-70 group-hover:opacity-100 filter brightness-125 contrast-125 drop-shadow-[0_0_8px_rgba(101,67,33,0.2)] group-hover:drop-shadow-[0_0_15px_rgba(101,67,33,0.5)] transition-all duration-300" 
          />
        </a>

        <!-- Montalvo Catering -->
        <a 
          href="https://caterin-pegaso.vercel.app/" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="group transition-all duration-300 transform hover:scale-110 flex items-center justify-center"
        >
          <img 
            src="/logo-catering.png" 
            alt="Montalvo Catering" 
            class="h-9 sm:h-11 w-auto object-contain opacity-70 group-hover:opacity-100 filter invert-[0.85] brightness-125 drop-shadow-[0_0_8px_rgba(255,255,255,0.1)] group-hover:drop-shadow-[0_0_15px_rgba(255,255,255,0.3)] transition-all duration-300" 
          />
        </a>

      </div>
      
    </div>
  </div>
</section>
