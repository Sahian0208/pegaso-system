---
---
<section id="tecnologia" class="py-24 relative overflow-hidden bg-cosmos-dark border-y border-gray-800">
  <!-- Watermark Map and Backlight Glows -->
  <div class="absolute right-[-10%] top-[10%] w-[600px] h-[600px] bg-contain bg-no-repeat opacity-[0.03] pointer-events-none select-none -z-10 mix-blend-screen" style="background-image: url('/wheel.png');"></div>
  <div class="absolute left-1/4 top-1/4 w-[400px] h-[400px] rounded-full bg-cosmos-blue/10 blur-[120px] pointer-events-none -z-10"></div>
  <div class="absolute right-1/4 bottom-1/4 w-[400px] h-[400px] rounded-full bg-gold-deep/5 blur-[120px] pointer-events-none -z-10"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <!-- Cabecera Limpia -->
    <div class="animate-on-scroll text-center max-w-4xl mx-auto mb-16">
      <h2 class="text-gold-deep text-[10px] sm:text-xs font-bold tracking-[0.2em] sm:tracking-[0.3em] uppercase mb-4 text-glow">INGENIERÍA DE SOFTWARE DE ALTO NIVEL</h2>
      <h3 class="text-3xl md:text-5xl font-normal font-heading mb-6 text-white tracking-wide">Sistemas Digitales <span class="italic text-gold-bright">Estables, Rápidos y Seguros</span></h3>
      <div class="w-16 h-px bg-gold-deep/50 mx-auto mb-8 shadow-[0_0_10px_rgba(136,192,208,0.8)]"></div>
      <p class="text-gray-300 text-base md:text-lg font-light leading-relaxed max-w-3xl mx-auto">
        Creamos plataformas digitales de alta ingeniería diseñadas para funcionar sin interrupciones, garantizando velocidad extrema y protegiendo la información de su empresa bajo estándares de seguridad avanzados.
      </p>
    </div>

    <!-- Bento Grid Layout: Compact & Clean -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-6 max-w-5xl mx-auto">
      
      <!-- Card 1: Alta Disponibilidad (lg:col-span-5) -->
      <div class="animate-on-scroll lg:col-span-5 glass-card p-6 flex flex-col justify-between rounded-xl border border-gray-800 relative group overflow-hidden transition-all hover:border-gold-deep/30">
        <!-- Inside Card Glow -->
        <div class="absolute bottom-0 inset-x-0 h-16 bg-gradient-to-t from-gold-deep/5 to-transparent pointer-events-none"></div>

        <!-- Diagrama SVG Explicativo (Grande y Centrado) -->
        <div class="w-full flex items-center justify-center py-6 mb-4">
          <svg viewBox="0 0 200 60" fill="none" stroke="currentColor" stroke-width="1.2" class="w-full max-w-[280px] h-20 sm:h-24 text-gray-500 group-hover:text-emerald-400 transition-colors">
            <!-- Server A -->
            <rect x="10" y="5" width="55" height="22" rx="3" fill="currentColor" fill-opacity="0.05" />
            <circle cx="20" cy="16" r="2" fill="currentColor" />
            <line x1="28" y1="16" x2="55" y2="16" />
            <text x="10" y="40" fill="currentColor" font-size="7" font-family="sans-serif" class="font-semibold tracking-wide">Servidor Principal</text>

            <!-- Server B (Backup) -->
            <rect x="135" y="5" width="55" height="22" rx="3" fill="currentColor" fill-opacity="0.05" />
            <circle cx="145" cy="16" r="2" fill="currentColor" />
            <line x1="153" y1="16" x2="180" y2="16" />
            <text x="135" y="40" fill="currentColor" font-size="7" font-family="sans-serif" class="font-semibold tracking-wide">Respaldo Activo</text>

            <!-- Connection line with arrow -->
            <path d="M75 16 h50" stroke-dasharray="3 3" />
            <path d="M102 12 l6 4-6 4" fill="currentColor" stroke="none" />
          </svg>
        </div>

        <!-- Card Text -->
        <div class="text-left relative z-10">
          <h4 class="text-base font-heading font-semibold text-white mb-2 text-glow">Sistemas que Nunca se Caen</h4>
          <p class="text-gray-400 text-xs sm:text-sm font-light leading-relaxed">
            Si un servidor principal falla, un sistema de respaldo entra en acción al instante. Su plataforma sigue activa las 24 horas del día, asegurando ventas continuas y cero interrupciones.
          </p>
        </div>
      </div>
      
      <!-- Card 2: Ciberseguridad (lg:col-span-7) -->
      <div class="animate-on-scroll lg:col-span-7 glass-card p-6 flex flex-col justify-between rounded-xl border border-gray-800 relative group overflow-hidden transition-all hover:border-cosmos-blue/30">
        <!-- Inside Card Glow -->
        <div class="absolute bottom-0 inset-x-0 h-16 bg-gradient-to-t from-cosmos-blue/10 to-transparent pointer-events-none"></div>

        <!-- Diagrama SVG Explicativo (Grande y Centrado) -->
        <div class="w-full flex items-center justify-center py-6 mb-4">
          <svg viewBox="0 0 200 60" fill="none" stroke="currentColor" stroke-width="1.2" class="w-full max-w-[320px] h-20 sm:h-24 text-gray-500 group-hover:text-cosmos-blue transition-colors">
            <!-- Data Node -->
            <circle cx="35" cy="20" r="12" fill="currentColor" fill-opacity="0.05" />
            <path d="M31 18 h8 v6 h-8 z" />
            <circle cx="35" cy="14" r="3" />
            <text x="12" y="44" fill="currentColor" font-size="7" font-family="sans-serif" class="font-semibold tracking-wide">Datos Protegidos</text>
            
            <!-- Firewall Barrier -->
            <path d="M85 8 v30" stroke-dasharray="2 2" />
            <text x="70" y="48" fill="currentColor" font-size="6" font-family="sans-serif">Muro de Seguridad</text>
            
            <!-- Shield -->
            <path d="M140 16 c0-5 8-8 20-8 s20 3 20 8 c0 15-8 25-20 30 c-12-5-20-15-20-30 z" fill="currentColor" fill-opacity="0.05" />
            <path d="M150 22 l6 6 l10-10" stroke-width="2" />
            <text x="138" y="52" fill="currentColor" font-size="7" font-family="sans-serif" class="font-semibold tracking-wide">Escudo de Red</text>

            <!-- Arrows connecting -->
            <path d="M52 20 h28 M90 20 h45" />
          </svg>
        </div>

        <!-- Card Text -->
        <div class="text-left relative z-10">
          <h4 class="text-base font-heading font-semibold text-white mb-2 text-glow">Protección de Datos y Ciberseguridad</h4>
          <p class="text-gray-400 text-xs sm:text-sm font-light leading-relaxed">
            Protegemos la información sensible de su empresa y de sus clientes contra accesos no autorizados. Implementamos encriptación avanzada y blindaje de red (Zero Trust) de nivel bancario.
          </p>
        </div>
      </div>
      
      <!-- Card 3: SaaS Inteligente (lg:col-span-7) -->
      <div class="animate-on-scroll lg:col-span-7 glass-card p-6 flex flex-col justify-between rounded-xl border border-gray-800 relative group overflow-hidden transition-all hover:border-cosmos-blue/30">
        <!-- Inside Card Glow -->
        <div class="absolute bottom-0 inset-x-0 h-16 bg-gradient-to-t from-cosmos-blue/10 to-transparent pointer-events-none"></div>

        <!-- Diagrama SVG Explicativo (Grande y Centrado) -->
        <div class="w-full flex items-center justify-center py-6 mb-4">
          <svg viewBox="0 0 200 60" fill="none" stroke="currentColor" stroke-width="1.2" class="w-full max-w-[320px] h-20 sm:h-24 text-gray-500 group-hover:text-amber-400 transition-colors">
            <!-- Data Input -->
            <rect x="10" y="8" width="45" height="20" rx="3" fill="currentColor" fill-opacity="0.05" />
            <line x1="18" y1="18" x2="35" y2="18" stroke-width="2" />
            <text x="10" y="42" fill="currentColor" font-size="7" font-family="sans-serif" class="font-medium">Datos Operativos</text>
            
            <!-- IA Processing Node -->
            <circle cx="95" cy="18" r="10" stroke-dasharray="2 2" />
            <!-- Small stars to represent AI spark -->
            <path d="M93 16l2 2 2-2-2-2z M97 22l1 1 1-1-1-1z" fill="currentColor" stroke="none" />
            <text x="80" y="42" fill="currentColor" font-size="7" font-family="sans-serif" class="font-medium">Inteligencia Artificial</text>

            <!-- Output Dashboard -->
            <rect x="145" y="8" width="45" height="22" rx="3" fill="currentColor" fill-opacity="0.05" stroke-width="1.5" />
            <path d="M150 24 l10-8 l6 4 l12-10" stroke-width="1.5" />
            <text x="142" y="42" fill="currentColor" font-size="7" font-family="sans-serif" class="font-medium">Gráficos y Métricas</text>
            
            <!-- Connection arrows -->
            <path d="M60 18 h20 M110 18 h30" />
          </svg>
        </div>

        <!-- Card Text -->
        <div class="text-left relative z-10">
          <h4 class="text-base font-heading font-semibold text-white mb-2 text-glow">Software Inteligente y Automatización</h4>
          <p class="text-gray-400 text-xs sm:text-sm font-light leading-relaxed">
            Desarrollamos aplicaciones a la medida que simplifican las tareas diarias de su empresa. Integramos Inteligencia Artificial y análisis de datos en tiempo real para optimizar sus operaciones.
          </p>
        </div>
      </div>
      
      <!-- Card 4: Ecosistema Tecnológico (lg:col-span-5) -->
      <div class="animate-on-scroll lg:col-span-5 glass-card p-6 flex flex-col justify-between rounded-xl border border-gray-800 relative group overflow-hidden transition-all hover:border-gold-deep/30">
        <!-- Inside Card Glow -->
        <div class="absolute bottom-0 inset-x-0 h-16 bg-gradient-to-t from-gold-deep/5 to-transparent pointer-events-none"></div>

        <!-- Diagrama SVG Explicativo (Grande y Centrado) -->
        <div class="w-full flex items-center justify-center py-6 mb-4">
          <svg viewBox="0 0 200 60" fill="none" stroke="currentColor" stroke-width="1.2" class="w-full max-w-[280px] h-20 sm:h-24 text-gray-500 group-hover:text-indigo-400 transition-colors">
            <!-- Device -->
            <rect x="15" y="8" width="22" height="28" rx="2" fill="currentColor" fill-opacity="0.05" />
            <line x1="26" y1="32" x2="26" y2="32" stroke-width="2" />
            <text x="12" y="48" fill="currentColor" font-size="7" font-family="sans-serif" class="font-medium">Diseño Visual</text>

            <!-- Lightning / Speed Arrow -->
            <path d="M60 22 l15 0-5 10 15-12-15 0 5-10z" fill="currentColor" stroke="none" />
            <text x="50" y="46" fill="currentColor" font-size="6" font-family="sans-serif">Velocidad Máxima</text>
            
            <!-- Cloud Database -->
            <path d="M140 28 c-3-2-3-8 1-10 c1-4 6-6 10-4 c2-2 7-2 9 1 c3-1 7 2 6 6 c2 1 2 6-1 7 z" fill="currentColor" fill-opacity="0.05" />
            <text x="132" y="48" fill="currentColor" font-size="7" font-family="sans-serif" class="font-medium">Servidor en la Nube</text>
            
            <!-- Connections -->
            <path d="M42 22 h12 M112 22 h23" stroke-dasharray="2 2" />
          </svg>
        </div>

        <!-- Card Text -->
        <div class="text-left relative z-10">
          <h4 class="text-base font-heading font-semibold text-white mb-2 text-glow">Ecosistema Tecnológico de Alta Velocidad</h4>
          <p class="text-gray-400 text-xs sm:text-sm font-light leading-relaxed">
            Conectamos de forma fluida el diseño visual rápido (Frontend) con bases de datos y servidores estables en la nube global. Esto garantiza que su web cargue de inmediato.
          </p>
        </div>
      </div>
      
    </div>
  </div>
</section>
