---
---
<section id="tecnologia" class="py-24 relative overflow-hidden bg-cosmos-dark border-y border-gray-800">
  <!-- Watermark Map and Backlight Glows -->
  <div class="absolute right-[-10%] top-[10%] w-[600px] h-[600px] bg-contain bg-no-repeat opacity-[0.03] pointer-events-none select-none -z-10 mix-blend-screen" style="background-image: url('/wheel.png');"></div>
  <div class="absolute left-1/4 top-1/4 w-[400px] h-[400px] rounded-full bg-cosmos-blue/10 blur-[120px] pointer-events-none -z-10"></div>
  <div class="absolute right-1/4 bottom-1/4 w-[400px] h-[400px] rounded-full bg-gold-deep/5 blur-[120px] pointer-events-none -z-10"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <!-- Cabecera Limpia -->
    <div class="animate-on-scroll text-center max-w-4xl mx-auto mb-16">
      <h2 class="text-gold-deep text-[10px] sm:text-xs font-bold tracking-[0.2em] sm:tracking-[0.3em] uppercase mb-4 text-glow">INGENIERÍA DE SOFTWARE DE ALTO NIVEL</h2>
      <h3 class="text-3xl md:text-5xl font-normal font-heading mb-6 text-white tracking-wide">Ecosistemas Digitales <span class="italic text-gold-bright">Resilientes y Robustos</span></h3>
      <div class="w-16 h-px bg-gold-deep/50 mx-auto mb-8 shadow-[0_0_10px_rgba(136,192,208,0.8)]"></div>
      <p class="text-gray-300 text-base md:text-lg font-light leading-relaxed max-w-3xl mx-auto">
        Construimos arquitecturas enterprise diseñadas para escalar de forma inquebrantable, integrando la estabilidad de una base sólida con la flexibilidad de la innovación continua.
      </p>
    </div>

    <!-- Bento Grid Layout: Compact & Clean -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-6 max-w-5xl mx-auto">
      
      <!-- Card 1: Alta Disponibilidad (lg:col-span-5) -->
      <div class="animate-on-scroll lg:col-span-5 glass-card p-6 flex flex-col justify-between rounded-xl border border-gray-800 relative group overflow-hidden transition-all hover:border-gold-deep/30">
        <!-- Inside Card Glow -->
        <div class="absolute bottom-0 inset-x-0 h-16 bg-gradient-to-t from-gold-deep/5 to-transparent pointer-events-none"></div>
        
        <!-- Compact Visual Status -->
        <div class="w-full mb-6">
          <div class="bg-cosmos-dark/60 border border-gray-850 rounded-lg p-3 flex items-center justify-between text-xs transition-colors group-hover:border-gray-800">
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
              <span class="font-bold text-white text-[11px]">Cluster Pegaso: Online</span>
            </div>
            <span class="text-gold-bright font-mono text-[10px] font-bold">99.99% Uptime</span>
          </div>
        </div>

        <!-- Card Text -->
        <div class="text-left relative z-10">
          <h4 class="text-base font-heading font-semibold text-white mb-2 text-glow">Alta Disponibilidad & Continuidad</h4>
          <p class="text-gray-400 text-xs sm:text-sm font-light leading-relaxed">
            Implementamos sistemas redundantes y elásticos (99.99%) que garantizan una fiabilidad ininterrumpida a nivel corporativo.
          </p>
        </div>
      </div>
      
      <!-- Card 2: Ciberseguridad (lg:col-span-7) -->
      <div class="animate-on-scroll lg:col-span-7 glass-card p-6 flex flex-col justify-between rounded-xl border border-gray-800 relative group overflow-hidden transition-all hover:border-cosmos-blue/30">
        <!-- Inside Card Glow -->
        <div class="absolute bottom-0 inset-x-0 h-16 bg-gradient-to-t from-cosmos-blue/10 to-transparent pointer-events-none"></div>

        <!-- Compact Visual Status -->
        <div class="w-full mb-6 flex flex-wrap gap-2">
          <span class="px-2.5 py-1 rounded bg-cosmos-dark/60 border border-gray-850 text-[10px] text-gray-400 font-mono transition-colors group-hover:border-gray-800">🔐 Cifrado: Activo</span>
          <span class="px-2.5 py-1 rounded bg-cosmos-blue/15 border border-cosmos-blue/35 text-[10px] text-cosmos-blue font-mono font-bold">🛡️ Zero Trust: Activo</span>
          <span class="px-2.5 py-1 rounded bg-cosmos-dark/60 border border-gray-850 text-[10px] text-gray-400 font-mono transition-colors group-hover:border-gray-800">🔍 Auditado</span>
        </div>

        <!-- Card Text -->
        <div class="text-left relative z-10">
          <h4 class="text-base font-heading font-semibold text-white mb-2 text-glow">Fortaleza Digital & Ciberseguridad</h4>
          <p class="text-gray-400 text-xs sm:text-sm font-light leading-relaxed">
            Desplegamos capas de defensa avanzadas (encriptación y Zero Trust) para salvaguardar su patrimonio digital con el máximo rigor.
          </p>
        </div>
      </div>
      
      <!-- Card 3: SaaS Inteligente (lg:col-span-7) -->
      <div class="animate-on-scroll lg:col-span-7 glass-card p-6 flex flex-col justify-between rounded-xl border border-gray-800 relative group overflow-hidden transition-all hover:border-cosmos-blue/30">
        <!-- Inside Card Glow -->
        <div class="absolute bottom-0 inset-x-0 h-16 bg-gradient-to-t from-cosmos-blue/10 to-transparent pointer-events-none"></div>

        <!-- Compact Visual Status -->
        <div class="w-full mb-6">
          <div class="bg-cosmos-dark/60 border border-gray-850 rounded-lg p-3 flex items-center justify-between text-xs transition-colors group-hover:border-gray-800">
            <span class="text-gray-400 font-mono text-[10px]">PegasoBI.query("ventas").integrate(IA)</span>
            <span class="px-2 py-0.5 rounded bg-gold-deep/20 border border-gold-deep/30 text-[9px] text-gold-bright font-semibold">Ejecutar ✦</span>
          </div>
        </div>

        <!-- Card Text -->
        <div class="text-left relative z-10">
          <h4 class="text-base font-heading font-semibold text-white mb-2 text-glow">SaaS Inteligente a Medida</h4>
          <p class="text-gray-400 text-xs sm:text-sm font-light leading-relaxed">
            Ingeniería de software exclusiva diseñada para resolver desafíos operativos complejos e integrar Business Intelligence de alto impacto.
          </p>
        </div>
      </div>
      
      <!-- Card 4: Ecosistema Tecnológico (lg:col-span-5) -->
      <div class="animate-on-scroll lg:col-span-5 glass-card p-6 flex flex-col justify-between rounded-xl border border-gray-800 relative group overflow-hidden transition-all hover:border-gold-deep/30">
        <!-- Inside Card Glow -->
        <div class="absolute bottom-0 inset-x-0 h-16 bg-gradient-to-t from-gold-deep/5 to-transparent pointer-events-none"></div>

        <!-- Compact Visual Status -->
        <div class="w-full mb-6">
          <div class="bg-cosmos-dark/60 border border-gray-850 rounded-lg p-3 flex items-center justify-between text-[10px] font-mono text-gray-400 transition-colors group-hover:border-gray-800">
            <span class="text-white">React/Astro</span>
            <span class="text-gray-655">➔</span>
            <span class="text-white">APIs / DB</span>
            <span class="text-gray-655">➔</span>
            <span class="text-white">AWS / GCP</span>
          </div>
        </div>

        <!-- Card Text -->
        <div class="text-left relative z-10">
          <h4 class="text-base font-heading font-semibold text-white mb-2 text-glow">Ecosistema Tecnológico</h4>
          <p class="text-gray-400 text-xs sm:text-sm font-light leading-relaxed">
            Frontend, Backend, Datos y Cloud integrados en un flujo continuo y eficiente para garantizar velocidad y escalabilidad.
          </p>
        </div>
      </div>
      
    </div>
  </div>
</section>
