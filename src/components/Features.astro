---
---
<section id="tecnologia" class="py-24 relative overflow-hidden bg-cosmos-dark border-y border-gray-800">
  <!-- Watermark Map and Backlight Glows -->
  <div class="absolute right-[-10%] top-[10%] w-[600px] h-[600px] bg-contain bg-no-repeat opacity-[0.03] pointer-events-none select-none -z-10 mix-blend-screen" style="background-image: url('/wheel.png');"></div>
  <div class="absolute left-1/4 top-1/4 w-[400px] h-[400px] rounded-full bg-cosmos-blue/10 blur-[120px] pointer-events-none -z-10"></div>
  <div class="absolute right-1/4 bottom-1/4 w-[400px] h-[400px] rounded-full bg-gold-deep/5 blur-[120px] pointer-events-none -z-10"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <!-- Cabecera Limpia -->
    <div class="animate-on-scroll text-center max-w-4xl mx-auto mb-16">
      <h2 class="text-gold-deep text-[10px] sm:text-xs font-bold tracking-[0.2em] sm:tracking-[0.3em] uppercase mb-4 text-glow">INGENIERÍA DE SOFTWARE DE ALTO NIVEL</h2>
      <h3 class="text-3xl md:text-5xl font-normal font-heading mb-6 text-white tracking-wide">Sistemas Digitales <span class="italic text-gold-bright">Estables, Rápidos y Seguros</span></h3>
      <div class="w-16 h-px bg-gold-deep/50 mx-auto mb-8 shadow-[0_0_10px_rgba(136,192,208,0.8)]"></div>
      <p class="text-gray-300 text-base md:text-lg font-light leading-relaxed max-w-3xl mx-auto">
        Creamos plataformas digitales de alta ingeniería diseñadas para funcionar sin interrupciones, garantizando velocidad extrema y protegiendo la información de su empresa bajo estándares de seguridad avanzados.
      </p>
    </div>

    <!-- Plataformas Especializadas Grid (4 Columnas) -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-5xl mx-auto mb-20">
      
      <!-- Pegasus Retail -->
      <div class="animate-on-scroll glass-card p-6 flex flex-col justify-between rounded-xl border border-gray-800 relative group overflow-hidden transition-all hover:border-gold-deep/30">
        <!-- Inside Card Glow -->
        <div class="absolute bottom-0 inset-x-0 h-16 bg-gradient-to-t from-gold-deep/5 to-transparent pointer-events-none"></div>
        <div>
          <!-- Icon: Storefront / network -->
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-10 h-10 text-gold-deep mb-5 group-hover:text-gold-bright transition-colors" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9z"/>
            <line x1="9" y1="22" x2="9" y2="16"/>
            <line x1="15" y1="22" x2="15" y2="16"/>
            <path d="M20 9H4"/>
            <circle cx="12" cy="13" r="2.5"/>
          </svg>
          
          <h4 class="text-xl font-heading text-white mb-2 group-hover:text-gold-bright transition-colors">Pegasus Retail</h4>
          <p class="text-[11px] text-gold-deep/80 italic font-montserrat font-light mb-4">
            Para distribuidoras, comercializadoras y empresas de ventas.
          </p>
          
          <!-- Feature List -->
          <ul class="space-y-3 border-t border-gray-800 pt-4 mb-6">
            <li class="flex items-center text-gray-300 font-light text-xs">
              <span class="text-gold-deep mr-2 text-glow">✦</span>
              Inventarios
            </li>
            <li class="flex items-center text-gray-300 font-light text-xs">
              <span class="text-gold-deep mr-2 text-glow">✦</span>
              Pedidos
            </li>
            <li class="flex items-center text-gray-300 font-light text-xs">
              <span class="text-gold-deep mr-2 text-glow">✦</span>
              Cobranza
            </li>
            <li class="flex items-center text-gray-300 font-light text-xs">
              <span class="text-gold-deep mr-2 text-glow">✦</span>
              Distribución
            </li>
            <li class="flex items-center text-gray-300 font-light text-xs">
              <span class="text-gold-deep mr-2 text-glow">✦</span>
              KPIs
            </li>
          </ul>
        </div>
        
        <!-- CTA -->
        <a href="https://wa.me/59179786916?text=Hola%20Pegasus%20Nexus!%20Me%20interesa%20conocer%20m%C3%A1s%20sobre%20Pegasus%20Retail." target="_blank" rel="noopener noreferrer" class="w-full py-2.5 text-center bg-transparent border border-gray-700 text-gray-300 hover:text-white hover:border-gold-deep font-semibold transition-all text-[10px] tracking-widest uppercase cursor-pointer">
          Consultar Solución
        </a>
      </div>

      <!-- Pegasus School -->
      <div class="animate-on-scroll glass-card p-6 flex flex-col justify-between rounded-xl border border-gray-800 relative group overflow-hidden transition-all hover:border-gold-deep/30">
        <!-- Inside Card Glow -->
        <div class="absolute bottom-0 inset-x-0 h-16 bg-gradient-to-t from-gold-deep/5 to-transparent pointer-events-none"></div>
        <div>
          <!-- Icon: Graduation cap -->
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-10 h-10 text-gold-deep mb-5 group-hover:text-gold-bright transition-colors" xmlns="http://www.w3.org/2000/svg">
            <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
            <path d="M6 12v5c0 2 2.5 3 6 3s6-1 6-3v-5"/>
            <circle cx="12" cy="10" r="1.5" fill="currentColor" fill-opacity="0.3"/>
          </svg>
          
          <h4 class="text-xl font-heading text-white mb-2 group-hover:text-gold-bright transition-colors">Pegasus School</h4>
          <p class="text-[11px] text-gold-deep/80 italic font-montserrat font-light mb-4">
            Para colegios, institutos y universidades.
          </p>
          
          <!-- Feature List -->
          <ul class="space-y-3 border-t border-gray-800 pt-4 mb-6">
            <li class="flex items-center text-gray-300 font-light text-xs">
              <span class="text-gold-deep mr-2 text-glow">✦</span>
              Gestión académica
            </li>
            <li class="flex items-center text-gray-300 font-light text-xs">
              <span class="text-gold-deep mr-2 text-glow">✦</span>
              Indicadores
            </li>
            <li class="flex items-center text-gray-300 font-light text-xs">
              <span class="text-gold-deep mr-2 text-glow">✦</span>
              Seguimiento estudiantil
            </li>
            <li class="flex items-center text-gray-300 font-light text-xs">
              <span class="text-gold-deep mr-2 text-glow">✦</span>
              Reportes
            </li>
          </ul>
        </div>
        
        <!-- CTA -->
        <a href="https://wa.me/59179786916?text=Hola%20Pegasus%20Nexus!%20Me%20interesa%20conocer%20m%C3%A1s%20sobre%20Pegasus%20School." target="_blank" rel="noopener noreferrer" class="w-full py-2.5 text-center bg-transparent border border-gray-700 text-gray-300 hover:text-white hover:border-gold-deep font-semibold transition-all text-[10px] tracking-widest uppercase cursor-pointer">
          Consultar Solución
        </a>
      </div>

      <!-- Pegasus BI -->
      <div class="animate-on-scroll glass-card p-6 flex flex-col justify-between rounded-xl border border-gray-800 relative group overflow-hidden transition-all hover:border-gold-deep/30">
        <!-- Inside Card Glow -->
        <div class="absolute bottom-0 inset-x-0 h-16 bg-gradient-to-t from-gold-deep/5 to-transparent pointer-events-none"></div>
        <div>
          <!-- Icon: Dashboard / metrics -->
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-10 h-10 text-gold-deep mb-5 group-hover:text-gold-bright transition-colors" xmlns="http://www.w3.org/2000/svg">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <line x1="9" y1="3" x2="9" y2="21"/>
            <line x1="9" y1="12" x2="21" y2="12"/>
            <line x1="6" y1="17" x2="6" y2="10"/>
            <path d="M12 8l3-3 4 4" stroke-linecap="round"/>
          </svg>
          
          <h4 class="text-xl font-heading text-white mb-2 group-hover:text-gold-bright transition-colors">Pegasus BI</h4>
          <p class="text-[11px] text-gold-deep/80 italic font-montserrat font-light mb-4">
            Centro de inteligencia empresarial.
          </p>
          
          <!-- Feature List -->
          <ul class="space-y-3 border-t border-gray-800 pt-4 mb-6">
            <li class="flex items-center text-gray-300 font-light text-xs">
              <span class="text-gold-deep mr-2 text-glow">✦</span>
              Dashboards
            </li>
            <li class="flex items-center text-gray-300 font-light text-xs">
              <span class="text-gold-deep mr-2 text-glow">✦</span>
              KPIs
            </li>
            <li class="flex items-center text-gray-300 font-light text-xs">
              <span class="text-gold-deep mr-2 text-glow">✦</span>
              Analítica avanzada
            </li>
          </ul>
        </div>
        
        <!-- CTA -->
        <a href="https://wa.me/59179786916?text=Hola%20Pegasus%20Nexus!%20Me%20interesa%20conocer%20m%C3%A1s%20sobre%20Pegasus%20BI." target="_blank" rel="noopener noreferrer" class="w-full py-2.5 text-center bg-transparent border border-gray-700 text-gray-300 hover:text-white hover:border-gold-deep font-semibold transition-all text-[10px] tracking-widest uppercase cursor-pointer">
          Consultar Solución
        </a>
      </div>

      <!-- Pegasus AI -->
      <div class="animate-on-scroll glass-card p-6 flex flex-col justify-between rounded-xl border border-gray-800 relative group overflow-hidden transition-all hover:border-gold-deep/30">
        <!-- Inside Card Glow -->
        <div class="absolute bottom-0 inset-x-0 h-16 bg-gradient-to-t from-gold-deep/5 to-transparent pointer-events-none"></div>
        <div>
          <!-- Icon: AI brain network -->
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-10 h-10 text-gold-deep mb-5 group-hover:text-gold-bright transition-colors" xmlns="http://www.w3.org/2000/svg">
            <path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.9-1M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.9-1"/>
            <circle cx="6" cy="12" r="1.5" fill="currentColor" stroke="none"/>
            <circle cx="18" cy="12" r="1.5" fill="currentColor" stroke="none"/>
            <path d="M6 12h12M12 5h4M8 19h4" stroke-dasharray="2 2"/>
          </svg>
          
          <h4 class="text-xl font-heading text-white mb-2 group-hover:text-gold-bright transition-colors">Pegasus AI</h4>
          <p class="text-[11px] text-gold-deep/80 italic font-montserrat font-light mb-4">
            Automatización e inteligencia artificial.
          </p>
          
          <!-- Feature List -->
          <ul class="space-y-3 border-t border-gray-800 pt-4 mb-6">
            <li class="flex items-center text-gray-300 font-light text-xs">
              <span class="text-gold-deep mr-2 text-glow">✦</span>
              Chatbots
            </li>
            <li class="flex items-center text-gray-300 font-light text-xs">
              <span class="text-gold-deep mr-2 text-glow">✦</span>
              Agentes IA
            </li>
            <li class="flex items-center text-gray-300 font-light text-xs">
              <span class="text-gold-deep mr-2 text-glow">✦</span>
              Automatización de soluciones
            </li>
          </ul>
        </div>
        
        <!-- CTA -->
        <a href="https://wa.me/59179786916?text=Hola%20Pegasus%20Nexus!%20Me%20interesa%20conocer%20m%C3%A1s%20sobre%20Pegasus%20AI." target="_blank" rel="noopener noreferrer" class="w-full py-2.5 text-center bg-transparent border border-gray-700 text-gray-300 hover:text-white hover:border-gold-deep font-semibold transition-all text-[10px] tracking-widest uppercase cursor-pointer">
          Consultar Solución
        </a>
      </div>

    </div>

    <!-- Separador y Subtítulo de Pilares -->
    <div class="animate-on-scroll text-center max-w-3xl mx-auto mb-12 mt-10">
      <h4 class="text-lg md:text-xl font-normal font-heading text-white tracking-wide">Nuestros Pilares Técnicos y Arquitectura</h4>
      <div class="w-12 h-px bg-gold-deep/30 mx-auto mt-4 mb-6"></div>
      <p class="text-gray-400 text-xs sm:text-sm font-light max-w-xl mx-auto">
        La infraestructura robusta y los estándares de seguridad que respaldan el funcionamiento estable de nuestras plataformas.
      </p>
    </div>

    <!-- Bento Grid Layout: Compact & Clean -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-6 max-w-5xl mx-auto">
      
      <!-- Card 1: Alta Disponibilidad (lg:col-span-5) -->
      <div class="animate-on-scroll lg:col-span-5 glass-card p-6 flex flex-col justify-between rounded-xl border border-gray-800 relative group overflow-hidden transition-all hover:border-gold-deep/30">
        <!-- Inside Card Glow -->
        <div class="absolute bottom-0 inset-x-0 h-16 bg-gradient-to-t from-gold-deep/5 to-transparent pointer-events-none"></div>

        <!-- Diagrama SVG Explicativo (Grande, Centrado, Brillante y Compacto) -->
        <div class="w-full flex items-center justify-center py-2 mb-2">
          <svg viewBox="0 0 300 80" fill="none" stroke="currentColor" stroke-width="1.6" class="w-full max-w-[280px] h-20 sm:h-24 text-gray-300 group-hover:text-emerald-400 transition-colors">
            <!-- Server A -->
            <rect x="25" y="10" width="60" height="25" rx="3" fill="currentColor" fill-opacity="0.08" />
            <circle cx="37" cy="22" r="2.5" fill="currentColor" />
            <line x1="47" y1="22" x2="75" y2="22" />
            <text x="55" y="52" fill="#E2E8F0" stroke="none" font-size="8.5" font-family="sans-serif" text-anchor="middle" class="font-medium tracking-wide">Servidor Principal</text>

            <!-- Enlace Redundante -->
            <path d="M95 22 h110" stroke-dasharray="3 3" />
            <path d="M152 18 l6 4-6 4" fill="currentColor" stroke="none" />
            <text x="150" y="14" fill="#94A3B8" stroke="none" font-size="6.5" font-family="sans-serif" text-anchor="middle" class="tracking-wider uppercase">Auto-Soporte</text>

            <!-- Server B (Backup) -->
            <rect x="215" y="10" width="60" height="25" rx="3" fill="currentColor" fill-opacity="0.08" />
            <circle cx="227" cy="22" r="2.5" fill="currentColor" />
            <line x1="237" y1="22" x2="265" y2="22" />
            <text x="245" y="52" fill="#E2E8F0" stroke="none" font-size="8.5" font-family="sans-serif" text-anchor="middle" class="font-medium tracking-wide">Respaldo Activo</text>
          </svg>
        </div>

        <!-- Card Text -->
        <div class="text-left relative z-10">
          <h4 class="text-base font-heading font-semibold text-white mb-2 text-glow">Sistemas que Nunca se Caen</h4>
          <p class="text-gray-400 text-xs sm:text-sm font-light leading-relaxed">
            Si un servidor principal falla, un sistema de respaldo entra en acción al instante. Su plataforma sigue activa las 24 horas del día, asegurando ventas continuas y cero interrupciones.
          </p>
        </div>
      </div>
      
      <!-- Card 2: Ciberseguridad (lg:col-span-7) -->
      <div class="animate-on-scroll lg:col-span-7 glass-card p-6 flex flex-col justify-between rounded-xl border border-gray-800 relative group overflow-hidden transition-all hover:border-cosmos-blue/30">
        <!-- Inside Card Glow -->
        <div class="absolute bottom-0 inset-x-0 h-16 bg-gradient-to-t from-cosmos-blue/10 to-transparent pointer-events-none"></div>

        <!-- Diagrama SVG Explicativo (Grande, Centrado, Brillante y Compacto) -->
        <div class="w-full flex items-center justify-center py-2 mb-2">
          <svg viewBox="0 0 300 80" fill="none" stroke="currentColor" stroke-width="1.6" class="w-full max-w-[320px] h-20 sm:h-24 text-gray-300 group-hover:text-cosmos-blue transition-colors">
            <!-- Data Node -->
            <circle cx="55" cy="22" r="14" fill="currentColor" fill-opacity="0.08" />
            <!-- Padlock visual inside circle -->
            <path d="M51 20 h8 v6 h-8 z" />
            <path d="M53 20 v-3 a2 2 0 0 1 4 0 v3" />
            <text x="55" y="52" fill="#E2E8F0" stroke="none" font-size="8.5" font-family="sans-serif" text-anchor="middle" class="font-medium tracking-wide">Datos Protegidos</text>
            
            <!-- Firewall Barrier -->
            <path d="M150 8 v28" stroke-dasharray="2 2" />
            <text x="150" y="52" fill="#94A3B8" stroke="none" font-size="6.5" font-family="sans-serif" text-anchor="middle" class="tracking-wider uppercase">Filtro Zero-Trust</text>
            
            <!-- Shield -->
            <path d="M225 20 c0-6 10-10 20-10 s20 4 20 10 c0 18-10 28-20 33 c-10-5-20-15-20-33 z" fill="currentColor" fill-opacity="0.08" />
            <path d="M237 26 l6 6 l10-10" stroke-width="2.2" />
            <text x="245" y="52" fill="#E2E8F0" stroke="none" font-size="8.5" font-family="sans-serif" text-anchor="middle" class="font-medium tracking-wide">Protección Activa</text>

            <!-- Arrows connecting -->
            <path d="M75 22 h65 M160 22 h58" />
          </svg>
        </div>

        <!-- Card Text -->
        <div class="text-left relative z-10">
          <h4 class="text-base font-heading font-semibold text-white mb-2 text-glow">Protección de Datos y Ciberseguridad</h4>
          <p class="text-gray-400 text-xs sm:text-sm font-light leading-relaxed">
            Protegemos la información sensible de su empresa y de sus clientes contra accesos no autorizados. Implementamos encriptación avanzada y blindaje de red (Zero Trust) de nivel bancario.
          </p>
        </div>
      </div>
      
      <!-- Card 3: SaaS Inteligente (lg:col-span-7) -->
      <div class="animate-on-scroll lg:col-span-7 glass-card p-6 flex flex-col justify-between rounded-xl border border-gray-800 relative group overflow-hidden transition-all hover:border-cosmos-blue/30">
        <!-- Inside Card Glow -->
        <div class="absolute bottom-0 inset-x-0 h-16 bg-gradient-to-t from-cosmos-blue/10 to-transparent pointer-events-none"></div>

        <!-- Diagrama SVG Explicativo (Grande, Centrado, Brillante y Compacto) -->
        <div class="w-full flex items-center justify-center py-2 mb-2">
          <svg viewBox="0 0 300 80" fill="none" stroke="currentColor" stroke-width="1.6" class="w-full max-w-[320px] h-20 sm:h-24 text-gray-300 group-hover:text-amber-400 transition-colors">
            <!-- Data Input -->
            <rect x="25" y="10" width="60" height="24" rx="3" fill="currentColor" fill-opacity="0.08" />
            <line x1="35" y1="22" x2="75" y2="22" stroke-width="2" />
            <text x="55" y="52" fill="#E2E8F0" stroke="none" font-size="8.5" font-family="sans-serif" text-anchor="middle" class="font-medium tracking-wide">Datos de Ventas</text>
            
            <!-- IA Processing Node -->
            <circle cx="150" cy="22" r="12" stroke-dasharray="2 2" />
            <!-- Small stars to represent AI spark -->
            <path d="M148 20l2 2 2-2-2-2z M152 26l1 1 1-1-1-1z" fill="currentColor" stroke="none" />
            <text x="150" y="52" fill="#E2E8F0" stroke="none" font-size="8.5" font-family="sans-serif" text-anchor="middle" class="font-medium tracking-wide">Procesamiento IA</text>

            <!-- Output Dashboard -->
            <rect x="215" y="10" width="60" height="24" rx="3" fill="currentColor" fill-opacity="0.08" stroke-width="1.5" />
            <path d="M225 26 l10-8 l6 4 l12-10" stroke-width="1.8" />
            <text x="245" y="52" fill="#E2E8F0" stroke="none" font-size="8.5" font-family="sans-serif" text-anchor="middle" class="font-medium tracking-wide">Gráficos y Reportes</text>
            
            <!-- Connection arrows -->
            <path d="M90 22 h48 M162 22 h48" />
          </svg>
        </div>

        <!-- Card Text -->
        <div class="text-left relative z-10">
          <h4 class="text-base font-heading font-semibold text-white mb-2 text-glow">Software Inteligente y Automatización</h4>
          <p class="text-gray-400 text-xs sm:text-sm font-light leading-relaxed">
            Desarrollamos aplicaciones a la medida que simplifican las tareas diarias de su empresa. Integramos Inteligencia Artificial y análisis de datos en tiempo real para optimizar sus operaciones.
          </p>
        </div>
      </div>
      
      <!-- Card 4: Ecosistema Tecnológico (lg:col-span-5) -->
      <div class="animate-on-scroll lg:col-span-5 glass-card p-6 flex flex-col justify-between rounded-xl border border-gray-800 relative group overflow-hidden transition-all hover:border-gold-deep/30">
        <!-- Inside Card Glow -->
        <div class="absolute bottom-0 inset-x-0 h-16 bg-gradient-to-t from-gold-deep/5 to-transparent pointer-events-none"></div>

        <!-- Diagrama SVG Explicativo (Grande, Centrado, Brillante y Compacto) -->
        <div class="w-full flex items-center justify-center py-2 mb-2">
          <svg viewBox="0 0 300 80" fill="none" stroke="currentColor" stroke-width="1.6" class="w-full max-w-[280px] h-20 sm:h-24 text-gray-300 group-hover:text-indigo-400 transition-colors">
            <!-- Device -->
            <rect x="35" y="8" width="40" height="28" rx="2" fill="currentColor" fill-opacity="0.08" />
            <line x1="55" y1="32" x2="55" y2="32" stroke-width="2" />
            <text x="55" y="52" fill="#E2E8F0" stroke="none" font-size="8.5" font-family="sans-serif" text-anchor="middle" class="font-medium tracking-wide">Diseño Frontend</text>

            <!-- Lightning / Speed Arrow -->
            <path d="M142 16 l12 0-4 8 12-10-12 0 4-8z" fill="currentColor" stroke="none" />
            <text x="150" y="52" fill="#94A3B8" stroke="none" font-size="6.5" font-family="sans-serif" text-anchor="middle" class="tracking-wider uppercase">Carga Inmediata</text>
            
            <!-- Cloud Database -->
            <path d="M225 28 c-3-2-3-8 1-10 c1-4 6-6 10-4 c2-2 7-2 9 1 c3-1 7 2 6 6 c2 1 2 6-1 7 z" fill="currentColor" fill-opacity="0.08" />
            <text x="245" y="52" fill="#E2E8F0" stroke="none" font-size="8.5" font-family="sans-serif" text-anchor="middle" class="font-medium tracking-wide">Nube de Datos</text>
            
            <!-- Connections -->
            <path d="M80 22 h48 M168 22 h50" stroke-dasharray="2 2" />
          </svg>
        </div>

        <!-- Card Text -->
        <div class="text-left relative z-10">
          <h4 class="text-base font-heading font-semibold text-white mb-2 text-glow">Ecosistema Tecnológico de Alta Velocidad</h4>
          <p class="text-gray-400 text-xs sm:text-sm font-light leading-relaxed">
            Conectamos de forma fluida el diseño visual rápido (Frontend) con bases de datos y servidores estables en la nube global. Esto garantiza que su web cargue de inmediato.
          </p>
        </div>
      </div>
      
    </div>
  </div>
</section>
