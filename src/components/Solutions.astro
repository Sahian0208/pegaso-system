---
---
<section id="soluciones" class="py-24 relative overflow-hidden bg-cosmos-dark border-t border-gray-800">
  <!-- Subtle star overlay -->
  <div class="absolute inset-0 bg-stars opacity-20 pointer-events-none"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Header -->
    <div class="animate-on-scroll text-center max-w-3xl mx-auto mb-20">
      <h2 class="text-gold-deep text-xs font-bold tracking-[0.3em] uppercase mb-4 text-glow">Nuestras Plataformas</h2>
      <h3 class="text-3xl md:text-5xl font-normal font-heading mb-6 text-white tracking-wide">
        Soluciones <span class="italic text-gold-bright">Especializadas</span>
      </h3>
      <div class="w-16 h-px bg-gold-deep/50 mx-auto shadow-[0_0_10px_rgba(136,192,208,0.8)]"></div>
    </div>

    <!-- Grid Layout: 4 Columns on desktop, 2 on tablet, 1 on mobile -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 max-w-7xl mx-auto">
      
      <!-- Pegasus Retail -->
      <div class="glass-card p-8 flex flex-col transition-all duration-300 rounded-none group relative">
        <!-- Icon: Storefront / network -->
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-12 h-12 text-gold-deep mb-6 group-hover:text-gold-bright transition-colors" xmlns="http://www.w3.org/2000/svg">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9z"/>
          <line x1="9" y1="22" x2="9" y2="16"/>
          <line x1="15" y1="22" x2="15" y2="16"/>
          <path d="M20 9H4"/>
          <circle cx="12" cy="13" r="2.5"/>
        </svg>
        
        <h4 class="text-2xl font-heading text-white mb-2 group-hover:text-gold-bright transition-colors">Pegasus Retail</h4>
        <p class="text-xs text-gold-deep/80 italic font-montserrat font-light mb-6">
          Para distribuidoras, comercializadoras y empresas de ventas.
        </p>
        
        <!-- Feature List -->
        <ul class="space-y-4 mb-10 border-t border-gray-800 pt-6 flex-grow">
          <li class="flex items-center text-gray-300 font-light text-sm">
            <span class="text-gold-deep mr-3 text-glow">✦</span>
            Inventarios
          </li>
          <li class="flex items-center text-gray-300 font-light text-sm">
            <span class="text-gold-deep mr-3 text-glow">✦</span>
            Pedidos
          </li>
          <li class="flex items-center text-gray-300 font-light text-sm">
            <span class="text-gold-deep mr-3 text-glow">✦</span>
            Cobranza
          </li>
          <li class="flex items-center text-gray-300 font-light text-sm">
            <span class="text-gold-deep mr-3 text-glow">✦</span>
            Distribución
          </li>
          <li class="flex items-center text-gray-300 font-light text-sm">
            <span class="text-gold-deep mr-3 text-glow">✦</span>
            KPIs
          </li>
        </ul>
        
        <!-- CTA -->
        <a href="https://wa.me/59179786916?text=Hola%20Pegasus%20Nexus!%20Me%20interesa%20conocer%20m%C3%A1s%20sobre%20Pegasus%20Retail." target="_blank" rel="noopener noreferrer" class="w-full py-3 text-center bg-transparent border border-gray-700 text-gray-300 hover:text-white hover:border-gold-deep font-semibold transition-all text-xs tracking-widest uppercase cursor-pointer">
          Consultar Solución
        </a>
      </div>

      <!-- Pegasus School -->
      <div class="glass-card p-8 flex flex-col transition-all duration-300 rounded-none group relative">
        <!-- Icon: Graduation cap -->
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-12 h-12 text-gold-deep mb-6 group-hover:text-gold-bright transition-colors" xmlns="http://www.w3.org/2000/svg">
          <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
          <path d="M6 12v5c0 2 2.5 3 6 3s6-1 6-3v-5"/>
          <circle cx="12" cy="10" r="1.5" fill="currentColor" fill-opacity="0.3"/>
        </svg>
        
        <h4 class="text-2xl font-heading text-white mb-2 group-hover:text-gold-bright transition-colors">Pegasus School</h4>
        <p class="text-xs text-gold-deep/80 italic font-montserrat font-light mb-6">
          Para colegios, institutos y universidades.
        </p>
        
        <!-- Feature List -->
        <ul class="space-y-4 mb-10 border-t border-gray-800 pt-6 flex-grow">
          <li class="flex items-center text-gray-300 font-light text-sm">
            <span class="text-gold-deep mr-3 text-glow">✦</span>
            Gestión académica
          </li>
          <li class="flex items-center text-gray-300 font-light text-sm">
            <span class="text-gold-deep mr-3 text-glow">✦</span>
            Indicadores
          </li>
          <li class="flex items-center text-gray-300 font-light text-sm">
            <span class="text-gold-deep mr-3 text-glow">✦</span>
            Seguimiento estudiantil
          </li>
          <li class="flex items-center text-gray-300 font-light text-sm">
            <span class="text-gold-deep mr-3 text-glow">✦</span>
            Reportes
          </li>
        </ul>
        
        <!-- CTA -->
        <a href="https://wa.me/59179786916?text=Hola%20Pegasus%20Nexus!%20Me%20interesa%20conocer%20m%C3%A1s%20sobre%20Pegasus%20School." target="_blank" rel="noopener noreferrer" class="w-full py-3 text-center bg-transparent border border-gray-700 text-gray-300 hover:text-white hover:border-gold-deep font-semibold transition-all text-xs tracking-widest uppercase cursor-pointer">
          Consultar Solución
        </a>
      </div>

      <!-- Pegasus BI -->
      <div class="glass-card p-8 flex flex-col transition-all duration-300 rounded-none group relative">
        <!-- Icon: Dashboard / metrics -->
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-12 h-12 text-gold-deep mb-6 group-hover:text-gold-bright transition-colors" xmlns="http://www.w3.org/2000/svg">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <line x1="9" y1="3" x2="9" y2="21"/>
          <line x1="9" y1="12" x2="21" y2="12"/>
          <line x1="6" y1="17" x2="6" y2="10"/>
          <path d="M12 8l3-3 4 4" stroke-linecap="round"/>
        </svg>
        
        <h4 class="text-2xl font-heading text-white mb-2 group-hover:text-gold-bright transition-colors">Pegasus BI</h4>
        <p class="text-xs text-gold-deep/80 italic font-montserrat font-light mb-6">
          Centro de inteligencia empresarial.
        </p>
        
        <!-- Feature List -->
        <ul class="space-y-4 mb-10 border-t border-gray-800 pt-6 flex-grow">
          <li class="flex items-center text-gray-300 font-light text-sm">
            <span class="text-gold-deep mr-3 text-glow">✦</span>
            Dashboards
          </li>
          <li class="flex items-center text-gray-300 font-light text-sm">
            <span class="text-gold-deep mr-3 text-glow">✦</span>
            KPIs
          </li>
          <li class="flex items-center text-gray-300 font-light text-sm">
            <span class="text-gold-deep mr-3 text-glow">✦</span>
            Analítica avanzada
          </li>
        </ul>
        
        <!-- CTA -->
        <a href="https://wa.me/59179786916?text=Hola%20Pegasus%20Nexus!%20Me%20interesa%20conocer%20m%C3%A1s%20sobre%20Pegasus%20BI." target="_blank" rel="noopener noreferrer" class="w-full py-3 text-center bg-transparent border border-gray-700 text-gray-300 hover:text-white hover:border-gold-deep font-semibold transition-all text-xs tracking-widest uppercase cursor-pointer">
          Consultar Solución
        </a>
      </div>

      <!-- Pegasus AI -->
      <div class="glass-card p-8 flex flex-col transition-all duration-300 rounded-none group relative">
        <!-- Icon: AI brain network -->
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-12 h-12 text-gold-deep mb-6 group-hover:text-gold-bright transition-colors" xmlns="http://www.w3.org/2000/svg">
          <path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.9-1M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.9-1"/>
          <circle cx="6" cy="12" r="1.5" fill="currentColor" stroke="none"/>
          <circle cx="18" cy="12" r="1.5" fill="currentColor" stroke="none"/>
          <path d="M6 12h12M12 5h4M8 19h4" stroke-dasharray="2 2"/>
        </svg>
        
        <h4 class="text-2xl font-heading text-white mb-2 group-hover:text-gold-bright transition-colors">Pegasus AI</h4>
        <p class="text-xs text-gold-deep/80 italic font-montserrat font-light mb-6">
          Automatización e inteligencia artificial.
        </p>
        
        <!-- Feature List -->
        <ul class="space-y-4 mb-10 border-t border-gray-800 pt-6 flex-grow">
          <li class="flex items-center text-gray-300 font-light text-sm">
            <span class="text-gold-deep mr-3 text-glow">✦</span>
            Chatbots
          </li>
          <li class="flex items-center text-gray-300 font-light text-sm">
            <span class="text-gold-deep mr-3 text-glow">✦</span>
            Agentes IA
          </li>
          <li class="flex items-center text-gray-300 font-light text-sm">
            <span class="text-gold-deep mr-3 text-glow">✦</span>
            Automatización de soluciones
          </li>
        </ul>
        
        <!-- CTA -->
        <a href="https://wa.me/59179786916?text=Hola%20Pegasus%20Nexus!%20Me%20interesa%20conocer%20m%C3%A1s%20sobre%20Pegasus%20AI." target="_blank" rel="noopener noreferrer" class="w-full py-3 text-center bg-transparent border border-gray-700 text-gray-300 hover:text-white hover:border-gold-deep font-semibold transition-all text-xs tracking-widest uppercase cursor-pointer">
          Consultar Solución
        </a>
      </div>

    </div>
  </div>
</section>
