---
---
<section id="paquetes" class="py-24 relative overflow-hidden bg-cosmos-dark border-t border-gray-800">
  <div class="absolute inset-0 bg-stars opacity-30"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="animate-on-scroll text-center max-w-3xl mx-auto mb-20">
      <h2 class="text-gold-deep text-xs font-bold tracking-[0.3em] uppercase mb-4 text-glow">Nuestros Planos de Solución</h2>
      <h3 class="text-3xl md:text-5xl font-normal font-heading mb-6 text-white tracking-wide">Modelos de <span class="italic text-gold-bright">Arquitectura Digital</span></h3>
      <div class="w-16 h-px bg-gold-deep/50 mx-auto shadow-[0_0_10px_rgba(136,192,208,0.8)]"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">
      
      <!-- PLAN FUNDACIÓN (WEB & LANDING) -->
      <div class="animate-on-scroll glass-card p-10 flex flex-col transition-all duration-500 rounded-none relative group">
        <!-- Icono Libra (Balanza) en SVG elegante y minimalista -->
        <svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="1.5" class="w-16 h-16 text-gold-deep mb-6 mx-auto opacity-80 group-hover:opacity-100 transition-opacity">
          <!-- Top decorative Star -->
          <path d="M50 12l2 4 4 2-4 2-2 4-2-4-4-2 4-2z" fill="currentColor" stroke="none" />
          <!-- Horizontal balance beam -->
          <line x1="20" y1="35" x2="80" y2="35" stroke="currentColor" stroke-width="2" />
          <!-- Center vertical pillar -->
          <line x1="50" y1="20" x2="50" y2="80" stroke="currentColor" stroke-dasharray="2 3" />
          <!-- Left scale strings and pan -->
          <line x1="20" y1="35" x2="15" y2="60" />
          <line x1="20" y1="35" x2="25" y2="60" />
          <path d="M10 60h20l-3 6h-14z" fill="currentColor" fill-opacity="0.1" />
          <!-- Right scale strings and pan -->
          <line x1="80" y1="35" x2="75" y2="60" />
          <line x1="80" y1="35" x2="85" y2="60" />
          <path d="M70 60h20l-3 6h-14z" fill="currentColor" fill-opacity="0.1" />
          <!-- Stand base -->
          <path d="M35 80h30" stroke-width="2" />
          <!-- Zodiac Glyph of Libra -->
          <path d="M42 70h16 M42 74c2-4 14-4 16 0" />
        </svg>

        <div class="mb-4 text-gray-400 font-bold tracking-[0.2em] text-xs uppercase border-b border-gray-700 pb-2">Plan Fundación</div>
        <div class="text-3xl font-heading text-white mb-6 group-hover:text-gold-bright transition-colors">Web & Landing</div>
        
        <p class="text-gray-300 mb-6 font-light leading-relaxed text-sm">
          Presencia digital optimizada y de alto impacto. Soluciones diseñadas para consolidar su marca de manera profesional y veloz.
        </p>

        <div class="bg-cosmos-dark/40 border border-gray-800 p-4 mb-6 rounded">
          <div class="text-gold-deep text-xs font-bold uppercase tracking-wider mb-1">Enfoque Técnico</div>
          <p class="text-gray-400 text-xs font-light leading-relaxed">
            JAMstack (Astro/Tailwind) para rendimiento crítico y tiempos de carga ultrarrápidos, ideal para posicionamiento y vitrina corporativa.
          </p>
        </div>

        <ul class="space-y-4 mb-10 border-t border-gray-800 pt-6 flex-grow">
          <li class="flex items-start text-gray-300 font-light text-sm">
            <span class="text-gold-deep mr-3 mt-1 text-glow">✦</span>
            Arquitectura optimizada (SSG para velocidad).
          </li>
          <li class="flex items-start text-gray-300 font-light text-sm">
            <span class="text-gold-deep mr-3 mt-1 text-glow">✦</span>
            Diseño Responsivo Premium (Mobile-first).
          </li>
          <li class="flex items-start text-gray-300 font-light text-sm">
            <span class="text-gold-deep mr-3 mt-1 text-glow">✦</span>
            Optimización SEO Básica y estructuración de meta-etiquetas para indexación avanzada.
          </li>
        </ul>

        <a href="https://wa.me/59179786916?text=Hola%20Pegaso%20System!%20Me%20interesa%20obtener%20m%C3%A1s%20informaci%C3%B3n%20sobre%20el%20Plan%20Fundaci%C3%B3n%20(Web%20%26%20Landing)." target="_blank" rel="noopener noreferrer" class="w-full py-4 text-center border border-gray-600 text-gray-300 hover:text-white hover:border-gold-deep font-semibold transition-colors text-xs tracking-widest uppercase cursor-pointer">
          Solicitar Plan Fundación
        </a>
      </div>

      <!-- PLAN SAAS INTEGRAL (DESTACADO) -->
      <div class="animate-on-scroll glass-card p-10 flex flex-col transition-all duration-500 border-t-2 border-gold-bright relative transform md:-translate-y-4 rounded-none shadow-[0_0_30px_rgba(136,192,208,0.2)] z-10 group">
        <div class="absolute top-0 inset-x-0 h-[2px] bg-gold-bright shadow-[0_0_15px_rgba(229,233,240,0.8)]"></div>
        <div class="absolute -top-3 right-8 bg-gold-bright text-cosmos-dark text-[10px] font-bold px-3 py-1 uppercase tracking-widest shadow-[0_0_10px_rgba(229,233,240,0.5)]">Destacado</div>
        
        <!-- Icono Leo (León) en SVG elegante -->
        <svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="1.5" class="w-16 h-16 text-gold-bright mb-6 mx-auto opacity-95 transition-all drop-shadow-[0_0_12px_rgba(255,255,255,0.3)]">
          <!-- Lion head shape -->
          <path d="M50 15 L25 35 L30 60 L50 85 L70 60 L75 35 Z" stroke-width="2" fill="currentColor" fill-opacity="0.05" />
          <!-- Inner geometry -->
          <line x1="50" y1="15" x2="50" y2="85" stroke-dasharray="1 3" />
          <line x1="25" y1="35" x2="75" y2="35" />
          <line x1="30" y1="60" x2="70" y2="60" />
          <path d="M35 35 L50 50 L65 35" />
          <path d="M50 50 L50 70 M42 60 L50 70 L58 60" />
          <!-- Stars -->
          <circle cx="50" cy="15" r="2.5" fill="#FFF" />
          <circle cx="25" cy="35" r="2.5" fill="#FFF" />
          <circle cx="75" cy="35" r="2.5" fill="#FFF" />
          <circle cx="50" cy="50" r="2" fill="#FFF" />
          <circle cx="50" cy="85" r="2.5" fill="#FFF" />
        </svg>

        <div class="mb-4 text-gold-bright font-bold tracking-[0.2em] text-xs uppercase border-b border-gold-deep/30 pb-2">Plan SaaS Integral</div>
        <div class="text-4xl font-heading text-white mb-6 text-glow">SaaS Completo</div>
        
        <p class="text-gray-200 mb-6 font-light leading-relaxed text-sm">
          Solución integral de software empresarial. Sistemas robustos con arquitectura escalable, bases de datos optimizadas y paneles de administración a medida.
        </p>

        <div class="bg-cosmos-dark/60 border border-gold-deep/20 p-4 mb-6 rounded shadow-[0_0_10px_rgba(255,255,255,0.05)]">
          <div class="text-gold-bright text-xs font-bold uppercase tracking-wider mb-1">Enfoque Técnico</div>
          <p class="text-gray-300 text-xs font-light leading-relaxed">
            Desarrollo full-stack (React/Angular/Astro + Backend Custom y DB Híbridas) para digitalización de procesos operativos complejos (POS, Inventarios, E-commerce).
          </p>
        </div>

        <ul class="space-y-4 mb-10 border-t border-gold-deep/20 pt-6 flex-grow">
          <li class="flex items-start text-gray-300 font-light text-sm">
            <span class="text-gold-bright mr-3 mt-1 text-glow">✦</span>
            Aplicación Web interactiva (SPA) de alto rendimiento.
          </li>
          <li class="flex items-start text-gray-300 font-light text-sm">
            <span class="text-gold-bright mr-3 mt-1 text-glow">✦</span>
            Seguridad de grado empresarial (JWT/OAuth) y gestión de roles avanzada.
          </li>
          <li class="flex items-start text-gray-300 font-light text-sm">
            <span class="text-gold-bright mr-3 mt-1 text-glow">✦</span>
            Integración fluida de Pasarelas de Pago y consumo de APIs de terceros.
          </li>
        </ul>

        <a href="https://wa.me/59179786916?text=Hola%20Pegaso%20System!%20Me%20interesa%20iniciar%20un%20proyecto%20con%20el%20Plan%20SaaS%20Integral." target="_blank" rel="noopener noreferrer" class="w-full py-4 text-center bg-transparent border border-gold-bright text-gold-bright hover:bg-gold-bright hover:text-cosmos-dark font-bold transition-all text-xs tracking-widest uppercase shadow-[0_0_15px_rgba(229,233,240,0.2)] cursor-pointer">
          Iniciar Proyecto SaaS
        </a>
      </div>

      <!-- SOLUCIÓN ENTERPRISE (CORPORATIVA & ESCALABLE) -->
      <div class="animate-on-scroll glass-card p-10 flex flex-col transition-all duration-500 rounded-none relative group">
        <!-- Icono Fénix/Tauro entrelazado SVG minimalista -->
        <svg viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="1.5" class="w-16 h-16 text-gold-deep mb-6 mx-auto opacity-80 group-hover:opacity-100 transition-opacity">
          <!-- Wings (Phoenix) -->
          <path d="M50 65 C30 50, 10 45, 5 30 C15 35, 30 40, 45 45 M50 65 C70 50, 90 45, 95 30 C85 35, 70 40, 55 45" stroke-width="1.5" />
          <!-- Inner layers of wings -->
          <path d="M50 65 C35 55, 20 50, 15 40 C25 43, 35 46, 47 48 M50 65 C65 55, 80 50, 85 40 C75 43, 65 46, 53 48" />
          <!-- Horns and Head (Tauro + Bird head) -->
          <circle cx="50" cy="55" r="10" fill="currentColor" fill-opacity="0.05" />
          <path d="M38 43 C38 33, 44 25, 50 25 C56 25, 62 33, 62 43" stroke-width="2" />
          <path d="M50 48l-3 5h6z" fill="currentColor" />
          <!-- Tail / Flames rising -->
          <path d="M50 65v20 M45 72l5 8 5-8" />
          <!-- Stars -->
          <circle cx="50" cy="25" r="2" fill="currentColor" />
          <circle cx="5" cy="30" r="2.5" fill="currentColor" />
          <circle cx="95" cy="30" r="2.5" fill="currentColor" />
          <circle cx="50" cy="85" r="2" fill="currentColor" />
        </svg>

        <div class="mb-4 text-gray-400 font-bold tracking-[0.2em] text-xs uppercase border-b border-gray-700 pb-2">Servicios Enterprise</div>
        <div class="text-3xl font-heading text-white mb-6">Enterprise</div>
        
        <p class="text-gray-300 mb-6 font-light leading-relaxed text-sm">
          Solución corporativa de alto rendimiento. Infraestructura de nube dedicada y escalabilidad sin límites para organizaciones líderes.
        </p>

        <div class="bg-cosmos-dark/40 border border-gray-800 p-4 mb-6 rounded">
          <div class="text-gold-deep text-xs font-bold uppercase tracking-wider mb-1">Enfoque Técnico</div>
          <p class="text-gray-400 text-xs font-light leading-relaxed">
            Arquitecturas de microservicios distribuidos, bases de datos híbridas y cloud elástica, orientadas a Business Intelligence y resiliencia crítica.
          </p>
        </div>

        <ul class="space-y-4 mb-10 border-t border-gray-800 pt-6 flex-grow">
          <li class="flex items-start text-gray-300 font-light text-sm">
            <span class="text-gold-deep mr-3 mt-1 text-glow">✦</span>
            SaaS Completo altamente escalable con arquitectura de nube dedicada.
          </li>
          <li class="flex items-start text-gray-300 font-light text-sm">
            <span class="text-gold-deep mr-3 mt-1 text-glow">✦</span>
            Despliegue en Infraestructura Dedicada (AWS/GCP/Azure) con elasticidad global.
          </li>
          <li class="flex items-start text-gray-300 font-light text-sm">
            <span class="text-gold-deep mr-3 mt-1 text-glow">✦</span>
            Soporte Continuo 24/7 de grado empresarial.
          </li>
          <li class="flex items-start text-gray-300 font-light text-sm">
            <span class="text-gold-deep mr-3 mt-1 text-glow">✦</span>
            Auditorías periódicas de seguridad, SLA estricto y Disaster Recovery avanzado.
          </li>
        </ul>

        <a href="https://wa.me/59179786916?text=Hola%20Pegaso%20System!%20Me%20gustar%C3%ADa%20agendar%20una%20consultor%C3%ADa%20para%20la%20Soluci%C3%B3n%20Enterprise." target="_blank" rel="noopener noreferrer" class="w-full py-4 text-center border border-gray-600 text-gray-300 hover:text-white hover:border-gold-deep font-semibold transition-colors text-xs tracking-widest uppercase cursor-pointer">
          Agendar Consultoría Enterprise
        </a>
      </div>

    </div>
  </div>
</section>
