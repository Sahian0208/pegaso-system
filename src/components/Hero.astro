---
---
<section id="inicio" class="relative min-h-screen flex flex-col pt-32 pb-12 overflow-hidden bg-cosmos-dark" style="background-image: url('/constelacion.png'); background-size: cover; background-position: center;">
  <!-- Dark overlay for text readability -->
  <div class="absolute inset-0 bg-cosmos-dark/70 backdrop-blur-[2px]"></div>
  
  <div class="absolute inset-0 bg-stars"></div>
  
  <!-- Lluvia de meteoritos intensa -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
    <!-- Capa 1: Lentos -->
    <div class="shooting-star" style="top: 10%; left: -10%; animation-delay: 0s; animation-duration: 15s;"></div>
    <div class="shooting-star" style="top: 30%; left: 40%; animation-delay: 4s; animation-duration: 12s;"></div>
    <div class="shooting-star" style="top: 60%; left: -20%; animation-delay: 8s; animation-duration: 18s;"></div>
    
    <!-- Capa 2: Rápidos y pequeños (Meteoritos) -->
    <div class="meteorite" style="top: 5%; left: 10%; animation-delay: 2s; animation-duration: 3s;"></div>
    <div class="meteorite" style="top: 25%; left: 50%; animation-delay: 5s; animation-duration: 4s;"></div>
    <div class="meteorite" style="top: 15%; left: 80%; animation-delay: 1s; animation-duration: 2.5s;"></div>
    <div class="meteorite" style="top: 45%; left: 5%; animation-delay: 7s; animation-duration: 3.5s;"></div>
    <div class="meteorite" style="top: 70%; left: 60%; animation-delay: 3s; animation-duration: 2.8s;"></div>
    <div class="meteorite" style="top: 85%; left: 20%; animation-delay: 9s; animation-duration: 4.2s;"></div>
    <div class="meteorite" style="top: -10%; left: 70%; animation-delay: 6s; animation-duration: 3.1s;"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full flex-grow flex items-center justify-center pb-24">
    
    <div class="text-center w-full max-w-4xl mx-auto flex flex-col items-center">
      <h2 class="text-gold-deep font-bold tracking-[0.4em] uppercase text-xs sm:text-sm mb-6 border-b border-gray-600/50 pb-2 inline-block">EXCELENCIA EN SOFTWARE</h2>
      
      <h1 class="flex flex-col mb-6 items-center w-full">
        <span class="font-montserrat text-5xl sm:text-8xl md:text-9xl lg:text-[10rem] font-black uppercase tracking-wider" style="color: #121420; text-shadow: 1px 1px 2px rgba(255, 255, 255, 0.25), -1px -1px 2px rgba(0, 0, 0, 0.8), 0 0 18px rgba(255, 255, 255, 0.55), 0 0 35px rgba(255, 255, 255, 0.25), 0 0 50px rgba(59, 130, 246, 0.15); filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.5));">PEGASUS</span>
        <span class="font-montserrat font-black text-2xl sm:text-4xl md:text-6xl tracking-[0.3em] uppercase mt-[-5px] sm:mt-[-15px] md:mt-[-20px]" style="color: #121420; text-shadow: 1px 1px 1px rgba(255, 255, 255, 0.2), 0 0 12px rgba(255, 255, 255, 0.45), 0 0 25px rgba(255, 255, 255, 0.2), 0 0 35px rgba(59, 130, 246, 0.15); filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.55));">NEXUS</span>
      </h1>
      
      <p id="hero-desc" class="text-base sm:text-xl md:text-2xl text-gray-300 font-montserrat font-light tracking-wide max-w-3xl mb-12 leading-relaxed drop-shadow-md flex flex-col gap-4 px-4 sm:px-0">
        <span class="text-white font-semibold text-glow text-lg sm:text-2xl">Transformamos datos, procesos y operaciones en decisiones inteligentes.</span>
        <span class="text-gray-300 text-sm sm:text-lg md:text-xl font-light">Ayudamos a empresas e instituciones a ordenar su gestión, automatizar tareas y crecer mediante sistemas SaaS, Business Intelligence e Inteligencia Artificial.</span>
      </p>
      
      <div id="hero-buttons" class="flex flex-col sm:flex-row gap-4 sm:gap-6 justify-center items-center w-full px-6 sm:px-0 max-w-md sm:max-w-none">
        <a href="https://wa.me/59179786916?text=Hola%20Pegasus%20Nexus!%20Me%20gustar%C3%ADa%20solicitar%20un%20diagn%C3%B3stico%20para%20mi%20empresa." target="_blank" rel="noopener noreferrer" class="glass-card text-white font-bold py-3.5 px-6 sm:py-4 sm:px-12 border border-cosmos-blue/50 hover:border-cosmos-blue hover:bg-cosmos-blue/10 transition-all text-xs sm:text-sm uppercase tracking-wider sm:tracking-widest text-center shadow-[0_0_20px_rgba(59,130,246,0.2)] hover:shadow-[0_0_30px_rgba(59,130,246,0.4)] w-full sm:w-auto min-w-0 sm:min-w-[240px] scale-100 hover:scale-105 cursor-pointer">
          Solicitar Diagnóstico
        </a>
        <a href="#por-que-nexus" class="text-gray-300 hover:text-cosmos-blue border border-transparent hover:border-cosmos-blue/30 py-3.5 px-6 sm:py-4 sm:px-12 transition-all text-xs sm:text-sm uppercase tracking-wider sm:tracking-widest text-center font-bold w-full sm:w-auto min-w-0 sm:min-w-[220px] scale-100 hover:scale-105 cursor-pointer">
          Ver Soluciones
        </a>
      </div>
    </div>

  </div>

  <!-- Wavy Divider adapted for dark mode -->
  <div class="absolute bottom-0 w-full overflow-hidden leading-[0] transform translate-y-1 z-20">
    <svg class="relative block w-[calc(100%+1.3px)] h-[80px]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
      <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V120H0V95.8C52.16,93.45,103.9,82.16,154,71.2,209.68,59,265.2,46.85,321.39,56.44Z" fill="#131726"></path>
    </svg>
  </div>
</section>

<style>
  .animate-float {
    animation: float 8s ease-in-out infinite;
  }
  .animate-pulse-slow {
    animation: pulse 6s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
  @keyframes float {
    0% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-15px) rotate(1deg); }
    100% { transform: translateY(0px) rotate(0deg); }
  }
</style>
