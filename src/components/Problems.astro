---
---
<section id="desafios" class="py-24 relative overflow-hidden bg-cosmos-dark border-t border-gray-800">
  <!-- Subtle star overlay -->
  <div class="absolute inset-0 bg-stars opacity-20 pointer-events-none"></div>
  <!-- Backlight glow -->
  <div class="absolute left-[-10%] top-[20%] w-[500px] h-[500px] rounded-full bg-cosmos-blue/5 blur-[120px] pointer-events-none -z-10"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      
      <!-- Left Column: Branding, Title, and CTA (Equivalent to "What you'll learn" in the example) -->
      <div class="lg:col-span-5 flex flex-col justify-center animate-on-scroll">
        <h2 class="text-gold-deep text-xs font-bold tracking-[0.3em] uppercase mb-4 text-glow">PROBLEMAS QUE RESOLVEMOS</h2>
        <h3 class="text-3xl md:text-4xl lg:text-5xl font-normal font-heading mb-6 text-white tracking-wide leading-tight">
          ¿Tu empresa enfrenta alguno de estos <span class="italic text-gold-bright">desafíos</span>?
        </h3>
        <div class="w-16 h-px bg-gold-deep/50 mb-8 shadow-[0_0_10px_rgba(136,192,208,0.8)]"></div>
        <p class="text-gray-300 text-base md:text-lg font-light leading-relaxed mb-8">
          Pegasus Nexus convierte estos desafíos en <span class="italic text-gold-bright font-semibold text-glow">procesos digitales inteligentes</span>.
        </p>
        <div class="flex">
          <a href="https://wa.me/59179786916?text=Hola%20Pegasus%20Nexus!%20Me%20gustar%C3%ADa%20solicitar%20un%20diagn%C3%B3stico%20para%20mi%20empresa%20y%20conocer%20c%C3%B3mo%20resolver%20nuestros%20desaf%C3%ADos." target="_blank" rel="noopener noreferrer" class="bg-transparent border border-gold-bright text-gold-bright hover:bg-gold-bright hover:text-cosmos-dark font-bold py-3.5 px-8 rounded-xl transition-all text-xs tracking-widest uppercase shadow-[0_0_15px_rgba(229,233,240,0.2)] hover:scale-105 transform cursor-pointer">
            Solicitar Diagnóstico Gratuito
          </a>
        </div>
      </div>
      
      <!-- Right Column: Challenges Grid (Horizontal layout matching cards in the example) -->
      <div class="lg:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-6 w-full">
        
        <!-- Challenge 1 -->
        <div class="glass-card p-6 flex flex-col transition-all duration-300 rounded-xl group relative border border-gray-800/85 hover:border-gold-deep/30 bg-cosmos-light/20 backdrop-blur-md">
          <!-- Subtle glow effect inside -->
          <div class="absolute bottom-0 inset-x-0 h-12 bg-gradient-to-t from-gold-deep/5 to-transparent pointer-events-none"></div>
          
          <div class="mb-4 text-gold-deep group-hover:text-gold-bright transition-colors">
            <!-- SVG Icon Excel -->
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8" xmlns="http://www.w3.org/2000/svg">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <line x1="3" y1="9" x2="21" y2="9"/>
              <line x1="3" y1="15" x2="21" y2="15"/>
              <line x1="9" y1="9" x2="9" y2="21"/>
              <line x1="15" y1="9" x2="15" y2="21"/>
              <path d="M6 5h2v2H6z" fill="currentColor" fill-opacity="0.3" stroke="none"/>
              <path d="M12 5h2v2h-2z" fill="currentColor" fill-opacity="0.3" stroke="none"/>
            </svg>
          </div>
          
          <h4 class="text-white font-heading text-base font-semibold mb-2 group-hover:text-gold-bright transition-colors">Archivos Dispersos</h4>
          <p class="text-gray-400 font-montserrat font-light leading-relaxed text-xs">
            Información fragmentada en múltiples archivos de Excel que dificultan la unificación de datos.
          </p>
        </div>
        
        <!-- Challenge 2 -->
        <div class="glass-card p-6 flex flex-col transition-all duration-300 rounded-xl group relative border border-gray-800/85 hover:border-gold-deep/30 bg-cosmos-light/20 backdrop-blur-md">
          <div class="absolute bottom-0 inset-x-0 h-12 bg-gradient-to-t from-gold-deep/5 to-transparent pointer-events-none"></div>
          
          <div class="mb-4 text-gold-deep group-hover:text-gold-bright transition-colors">
            <!-- SVG Icon Manual Processes -->
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8" xmlns="http://www.w3.org/2000/svg">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 6v6l4 2"/>
              <path d="M19 12a7 7 0 0 1-7 7" stroke-dasharray="2 2"/>
              <path d="M5 12a7 7 0 0 1 7-7" stroke-dasharray="2 2"/>
            </svg>
          </div>
          
          <h4 class="text-white font-heading text-base font-semibold mb-2 group-hover:text-gold-bright transition-colors">Procesos Manuales</h4>
          <p class="text-gray-400 font-montserrat font-light leading-relaxed text-xs">
            Tareas repetitivas que consumen el valioso tiempo de tus colaboradores y restan eficiencia.
          </p>
        </div>

        <!-- Challenge 3 -->
        <div class="glass-card p-6 flex flex-col transition-all duration-300 rounded-xl group relative border border-gray-800/85 hover:border-gold-deep/30 bg-cosmos-light/20 backdrop-blur-md">
          <div class="absolute bottom-0 inset-x-0 h-12 bg-gradient-to-t from-gold-deep/5 to-transparent pointer-events-none"></div>
          
          <div class="mb-4 text-gold-deep group-hover:text-gold-bright transition-colors">
            <!-- SVG Icon Lack of Indicators -->
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8" xmlns="http://www.w3.org/2000/svg">
              <path d="M3 3v18h18"/>
              <path d="M18.7 8l-5.1 5.2-2.8-2.7L7 14.3" stroke-dasharray="1 1"/>
              <circle cx="18.7" cy="8" r="2" fill="currentColor" fill-opacity="0.2" stroke="none"/>
              <path d="M12 7h2M12 11h5" stroke-dasharray="2 2"/>
            </svg>
          </div>
          
          <h4 class="text-white font-heading text-base font-semibold mb-2 group-hover:text-gold-bright transition-colors">Falta de Indicadores</h4>
          <p class="text-gray-400 font-montserrat font-light leading-relaxed text-xs">
            Inexistencia de métricas precisas o KPIs claros que te permitan tomar mejores decisiones de negocio.
          </p>
        </div>

        <!-- Challenge 4 -->
        <div class="glass-card p-6 flex flex-col transition-all duration-300 rounded-xl group relative border border-gray-800/85 hover:border-gold-deep/30 bg-cosmos-light/20 backdrop-blur-md">
          <div class="absolute bottom-0 inset-x-0 h-12 bg-gradient-to-t from-gold-deep/5 to-transparent pointer-events-none"></div>
          
          <div class="mb-4 text-gold-deep group-hover:text-gold-bright transition-colors">
            <!-- SVG Icon Inventory Control -->
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2L3 7l9 5 9-5-9-5z"/>
              <path d="M3 7v10l9 5M21 7v10l-9 5"/>
              <path d="M12 12v10"/>
              <circle cx="12" cy="17" r="3" stroke-dasharray="2 2"/>
            </svg>
          </div>
          
          <h4 class="text-white font-heading text-base font-semibold mb-2 group-hover:text-gold-bright transition-colors">Ventas e Inventario</h4>
          <p class="text-gray-400 font-montserrat font-light leading-relaxed text-xs">
            Dificultades para controlar tus niveles de stock, movimientos de almacén e histórico de ventas.
          </p>
        </div>

        <!-- Challenge 5 -->
        <div class="glass-card p-6 flex flex-col transition-all duration-300 rounded-xl group relative border border-gray-800/85 hover:border-gold-deep/30 bg-cosmos-light/20 backdrop-blur-md">
          <div class="absolute bottom-0 inset-x-0 h-12 bg-gradient-to-t from-gold-deep/5 to-transparent pointer-events-none"></div>
          
          <div class="mb-4 text-gold-deep group-hover:text-gold-bright transition-colors">
            <!-- SVG Icon Integration -->
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8" xmlns="http://www.w3.org/2000/svg">
              <circle cx="6" cy="6" r="3"/>
              <circle cx="18" cy="6" r="3"/>
              <circle cx="12" cy="18" r="3"/>
              <line x1="9" y1="6" x2="15" y2="6" stroke-dasharray="2 2"/>
              <line x1="7.5" y1="8.5" x2="10.5" y2="15.5" stroke-dasharray="2 2"/>
              <line x1="16.5" y1="8.5" x2="13.5" y2="15.5" stroke-dasharray="2 2"/>
            </svg>
          </div>
          
          <h4 class="text-white font-heading text-base font-semibold mb-2 group-hover:text-gold-bright transition-colors">Desconexión de Áreas</h4>
          <p class="text-gray-400 font-montserrat font-light leading-relaxed text-xs">
            Falta de integración y flujos de información continuos entre los diferentes departamentos.
          </p>
        </div>

        <!-- Challenge 6 -->
        <div class="glass-card p-6 flex flex-col transition-all duration-300 rounded-xl group relative border border-gray-800/85 hover:border-gold-deep/30 bg-cosmos-light/20 backdrop-blur-md">
          <div class="absolute bottom-0 inset-x-0 h-12 bg-gradient-to-t from-gold-deep/5 to-transparent pointer-events-none"></div>
          
          <div class="mb-4 text-gold-deep group-hover:text-gold-bright transition-colors">
            <!-- SVG Icon Visibility -->
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-8 h-8" xmlns="http://www.w3.org/2000/svg">
              <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/>
              <circle cx="12" cy="12" r="3"/>
              <path d="M12 2v2M12 20v2" stroke-dasharray="2 2"/>
            </svg>
          </div>
          
          <h4 class="text-white font-heading text-base font-semibold mb-2 group-hover:text-gold-bright transition-colors">Visibilidad de Negocio</h4>
          <p class="text-gray-400 font-montserrat font-light leading-relaxed text-xs">
            Baja visibilidad del rendimiento general, dificultando la planificación y crecimiento de la empresa.
          </p>
        </div>

      </div>
    </div>
  </div>
</section>
