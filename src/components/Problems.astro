---
---
<section id="desafios" class="pt-36 pb-24 relative overflow-hidden" style="background-color: #131726;">
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <!-- Split Layout Grid: Left Header, Right Cards -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start mb-20">
      
      <!-- Left Column: Header (4 Columns on large screen) -->
      <div class="lg:col-span-4 text-center lg:text-left flex flex-col items-center lg:items-start select-none">
        <h2 class="text-gold-deep text-[10px] sm:text-xs font-bold tracking-[0.2em] sm:tracking-[0.3em] uppercase mb-4 text-glow">Problemas que resolvemos</h2>
        <h3 class="text-3xl md:text-5xl font-normal font-heading mb-6 text-white tracking-wide leading-tight">
          ¿Tu empresa enfrenta alguno de estos <span class="italic text-gold-bright block lg:inline">desafíos</span>?
        </h3>
        <div class="w-16 h-px bg-gold-deep/50 lg:mx-0 mx-auto shadow-[0_0_10px_rgba(136,192,208,0.8)] mb-8"></div>
        <p class="text-gray-400 font-montserrat font-light text-sm sm:text-base leading-relaxed max-w-md">
          Las ineficiencias operativas y la falta de datos claros frenan el crecimiento. Pegasus Nexus transforma estos obstáculos cotidianos en flujos digitales automatizados y listos para la toma de decisiones.
        </p>
      </div>

      <!-- Right Column: Horizontal/Grid Row of Cards (8 Columns) -->
      <div class="lg:col-span-8 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
        
        <!-- Challenge 1 -->
        <div class="animate-on-scroll glass-card p-6 flex flex-col justify-between rounded-xl border border-gray-800/40 relative group overflow-hidden transition-all hover:border-cosmos-blue/30 h-full" style="background: linear-gradient(135deg, rgba(255, 255, 255, 0.01) 0%, rgba(11, 17, 32, 0.08) 100%);">
          <div>
            <!-- SVG Icon Excel -->
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-10 h-10 text-cosmos-blue mb-5 group-hover:text-gold-bright transition-colors" xmlns="http://www.w3.org/2000/svg">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <line x1="3" y1="9" x2="21" y2="9"/>
              <line x1="3" y1="15" x2="21" y2="15"/>
              <line x1="9" y1="3" x2="9" y2="21"/>
              <line x1="15" y1="3" x2="15" y2="21"/>
            </svg>
            <h4 class="text-lg font-heading font-semibold text-white mb-2 group-hover:text-gold-bright transition-colors">Archivos Excel</h4>
            <p class="text-gray-400 font-montserrat font-light leading-relaxed text-xs">
              Información fragmentada y duplicada en múltiples planillas y formatos incompatibles.
            </p>
          </div>
        </div>

        <!-- Challenge 2 -->
        <div class="animate-on-scroll glass-card p-6 flex flex-col justify-between rounded-xl border border-gray-800/40 relative group overflow-hidden transition-all hover:border-cosmos-blue/30 h-full" style="background: linear-gradient(135deg, rgba(255, 255, 255, 0.01) 0%, rgba(11, 17, 32, 0.08) 100%);">
          <div>
            <!-- SVG Icon Manual Processes -->
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-10 h-10 text-cosmos-blue mb-5 group-hover:text-gold-bright transition-colors" xmlns="http://www.w3.org/2000/svg">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 6v6l4 2"/>
              <path d="M19 12a7 7 0 0 1-7 7" stroke-dasharray="2 2"/>
              <path d="M5 12a7 7 0 0 1 7-7" stroke-dasharray="2 2"/>
            </svg>
            <h4 class="text-lg font-heading font-semibold text-white mb-2 group-hover:text-gold-bright transition-colors">Tareas Manuales</h4>
            <p class="text-gray-400 font-montserrat font-light leading-relaxed text-xs">
              Operaciones repetitivas del día a día que consumen tiempo valioso y causan errores.
            </p>
          </div>
        </div>

        <!-- Challenge 3 -->
        <div class="animate-on-scroll glass-card p-6 flex flex-col justify-between rounded-xl border border-gray-800/40 relative group overflow-hidden transition-all hover:border-cosmos-blue/30 h-full" style="background: linear-gradient(135deg, rgba(255, 255, 255, 0.01) 0%, rgba(11, 17, 32, 0.08) 100%);">
          <div>
            <!-- SVG Icon Lack of Indicators -->
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-10 h-10 text-cosmos-blue mb-5 group-hover:text-gold-bright transition-colors" xmlns="http://www.w3.org/2000/svg">
              <path d="M3 3v18h18"/>
              <path d="M18.7 8l-5.1 5.2-2.8-2.7L7 14.3" stroke-dasharray="1 1"/>
              <circle cx="18.7" cy="8" r="2" fill="currentColor" fill-opacity="0.2" stroke="none"/>
              <path d="M12 7h2M12 11h5" stroke-dasharray="2 2"/>
            </svg>
            <h4 class="text-lg font-heading font-semibold text-white mb-2 group-hover:text-gold-bright transition-colors">Falta de KPIs</h4>
            <p class="text-gray-400 font-montserrat font-light leading-relaxed text-xs">
              Ausencia de indicadores claros en tiempo real para tomar decisiones de negocio seguras.
            </p>
          </div>
        </div>

        <!-- Challenge 4 -->
        <div class="animate-on-scroll glass-card p-6 flex flex-col justify-between rounded-xl border border-gray-800/40 relative group overflow-hidden transition-all hover:border-cosmos-blue/30 h-full" style="background: linear-gradient(135deg, rgba(255, 255, 255, 0.01) 0%, rgba(11, 17, 32, 0.08) 100%);">
          <div>
            <!-- SVG Icon Inventory Control -->
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-10 h-10 text-cosmos-blue mb-5 group-hover:text-gold-bright transition-colors" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2L3 7l9 5 9-5-9-5z"/>
              <path d="M3 7v10l9 5M21 7v10l-9 5"/>
              <path d="M12 12v10"/>
              <circle cx="12" cy="17" r="3" stroke-dasharray="2 2"/>
            </svg>
            <h4 class="text-lg font-heading font-semibold text-white mb-2 group-hover:text-gold-bright transition-colors">Ventas y Stock</h4>
            <p class="text-gray-400 font-montserrat font-light leading-relaxed text-xs">
              Dificultad para controlar existencias y conciliar los flujos de ventas diarias.
            </p>
          </div>
        </div>

        <!-- Challenge 5 -->
        <div class="animate-on-scroll glass-card p-6 flex flex-col justify-between rounded-xl border border-gray-800/40 relative group overflow-hidden transition-all hover:border-cosmos-blue/30 h-full" style="background: linear-gradient(135deg, rgba(255, 255, 255, 0.01) 0%, rgba(11, 17, 32, 0.08) 100%);">
          <div>
            <!-- SVG Icon Integration -->
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-10 h-10 text-cosmos-blue mb-5 group-hover:text-gold-bright transition-colors" xmlns="http://www.w3.org/2000/svg">
              <circle cx="6" cy="6" r="3"/>
              <circle cx="18" cy="6" r="3"/>
              <circle cx="12" cy="18" r="3"/>
              <line x1="9" y1="6" x2="15" y2="6" stroke-dasharray="2 2"/>
              <line x1="7.5" y1="8.5" x2="10.5" y2="15.5" stroke-dasharray="2 2"/>
              <line x1="16.5" y1="8.5" x2="13.5" y2="15.5" stroke-dasharray="2 2"/>
            </svg>
            <h4 class="text-lg font-heading font-semibold text-white mb-2 group-hover:text-gold-bright transition-colors">Áreas Aisladas</h4>
            <p class="text-gray-400 font-montserrat font-light leading-relaxed text-xs">
              Desconexión y falta de flujo integrado de información entre los departamentos.
            </p>
          </div>
        </div>

        <!-- Challenge 6 -->
        <div class="animate-on-scroll glass-card p-6 flex flex-col justify-between rounded-xl border border-gray-800/40 relative group overflow-hidden transition-all hover:border-cosmos-blue/30 h-full" style="background: linear-gradient(135deg, rgba(255, 255, 255, 0.01) 0%, rgba(11, 17, 32, 0.08) 100%);">
          <div>
            <!-- SVG Icon Visibility -->
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-10 h-10 text-cosmos-blue mb-5 group-hover:text-gold-bright transition-colors" xmlns="http://www.w3.org/2000/svg">
              <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/>
              <circle cx="12" cy="12" r="3"/>
              <path d="M12 2v2M12 20v2" stroke-dasharray="2 2"/>
            </svg>
            <h4 class="text-lg font-heading font-semibold text-white mb-2 group-hover:text-gold-bright transition-colors">Poca Visibilidad</h4>
            <p class="text-gray-400 font-montserrat font-light leading-relaxed text-xs">
              Dificultad para visualizar el estado del negocio de manera oportuna y consolidada.
            </p>
          </div>
        </div>

      </div>

    </div>

    <!-- Redesigned CTA Section: Modern Split-Row Banner -->
    <div class="animate-on-scroll glass-card p-8 md:p-10 max-w-5xl mx-auto rounded-2xl border border-gray-800/50 relative overflow-hidden group shadow-[0_0_40px_rgba(59,130,246,0.1)] hover:border-cosmos-blue/30 transition-all duration-500" style="background: linear-gradient(135deg, rgba(3, 7, 18, 0.8) 0%, rgba(11, 17, 32, 0.9) 100%);">
      <!-- Background Ambient Glows on Left and Right -->
      <div class="absolute left-0 top-0 w-72 h-72 bg-gold-deep/5 rounded-full blur-[60px] pointer-events-none -z-10 group-hover:bg-gold-deep/10 transition-all duration-500"></div>
      <div class="absolute right-0 bottom-0 w-72 h-72 bg-cosmos-blue/10 rounded-full blur-[60px] pointer-events-none -z-10 group-hover:bg-cosmos-blue/15 transition-all duration-500"></div>
      
      <!-- Neural / Constellation Vector Decorators (Left and Right) -->
      <div class="absolute left-[-2%] top-1/2 -translate-y-1/2 w-48 h-full opacity-10 group-hover:opacity-20 transition-opacity duration-500 pointer-events-none -z-10 select-none">
        <svg viewBox="0 0 100 100" class="w-full h-full text-gold-deep" fill="none" stroke="currentColor" stroke-width="0.8">
          <circle cx="10" cy="30" r="2" fill="currentColor"></circle>
          <circle cx="40" cy="20" r="1.5" fill="currentColor"></circle>
          <circle cx="30" cy="60" r="2" fill="currentColor"></circle>
          <circle cx="20" cy="80" r="1.5" fill="currentColor"></circle>
          <line x1="10" y1="30" x2="40" y2="20"></line>
          <line x1="10" y1="30" x2="30" y2="60"></line>
          <line x1="40" y1="20" x2="30" y2="60"></line>
          <line x1="30" y1="60" x2="20" y2="80"></line>
        </svg>
      </div>
      <div class="absolute right-[-2%] top-1/2 -translate-y-1/2 w-48 h-full opacity-10 group-hover:opacity-20 transition-opacity duration-500 pointer-events-none -z-10 select-none">
        <svg viewBox="0 0 100 100" class="w-full h-full text-cosmos-blue" fill="none" stroke="currentColor" stroke-width="0.8">
          <circle cx="90" cy="40" r="2" fill="currentColor"></circle>
          <circle cx="60" cy="30" r="1.5" fill="currentColor"></circle>
          <circle cx="70" cy="70" r="2" fill="currentColor"></circle>
          <circle cx="80" cy="20" r="1.5" fill="currentColor"></circle>
          <line x1="90" y1="40" x2="60" y2="30"></line>
          <line x1="90" y1="40" x2="70" y2="70"></line>
          <line x1="60" y1="30" x2="70" y2="70"></line>
          <line x1="60" y1="30" x2="80" y2="20"></line>
        </svg>
      </div>

      <div class="flex flex-col md:flex-row items-center justify-between gap-8 relative z-10">
        <!-- Left content -->
        <div class="max-w-2xl text-center md:text-left flex flex-col items-center md:items-start">
          <!-- Pill Tag -->
          <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-cosmos-blue/10 border border-cosmos-blue/20 text-glow text-[10px] uppercase tracking-wider text-cosmos-blue font-bold mb-4">
            <span class="w-1.5 h-1.5 rounded-full bg-cosmos-blue animate-pulse"></span>
            Diagnóstico Nexus
          </div>
          
          <h3 class="text-xl md:text-3xl text-white font-heading font-normal tracking-wide mb-3 leading-snug">
            Pegasus Nexus convierte estos desafíos en <span class="italic text-gold-bright font-semibold text-glow block sm:inline">procesos digitales inteligentes</span>.
          </h3>
          
          <p class="text-xs sm:text-sm text-gray-400 font-montserrat font-light leading-relaxed">
            Conectamos y automatizamos tus operaciones comerciales para maximizar la productividad y visibilidad de tu negocio.
          </p>
        </div>
        
        <!-- Right content -->
        <div class="flex flex-col items-center justify-center shrink-0 w-full md:w-auto">
          <a href="https://wa.me/59179786916?text=Hola%20Pegasus%20Nexus!%20Me%20gustar%C3%ADa%20solicitar%20un%20diagn%C3%B3stico%20para%20mi%20empresa%20y%20conocer%20c%C3%B3mo%20resolver%20nuestros%20desaf%C3%ADos." target="_blank" rel="noopener noreferrer" class="w-full md:w-auto flex items-center justify-center gap-3 bg-cosmos-dark border border-cosmos-blue/50 text-white font-bold py-4 px-8 sm:px-10 rounded-xl transition-all text-xs tracking-widest uppercase shadow-[0_0_20px_rgba(59,130,246,0.15)] hover:shadow-[0_0_30px_rgba(59,130,246,0.4)] hover:bg-cosmos-blue/10 hover:border-cosmos-blue hover:scale-105 transform duration-300 cursor-pointer group/btn">
            Solicitar Diagnóstico Gratuito
            <svg class="w-4 h-4 text-white group-hover/btn:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
          </a>
          
          <p class="text-[10px] text-gray-500 font-montserrat font-light tracking-wide mt-3 text-center">
            Sin costo de compromiso • Diagnóstico personalizado
          </p>
        </div>
      </div>
    </div>
    
  </div>
</section>
