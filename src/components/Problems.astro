---
---
<section id="desafios" class="py-24 relative overflow-hidden" style="background-color: #131726;">
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <!-- Header -->
    <div class="animate-on-scroll text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-gold-deep text-xs font-bold tracking-[0.3em] uppercase mb-4 text-glow">Problemas que resolvemos</h2>
      <h3 class="text-3xl md:text-5xl font-normal font-heading mb-6 text-white tracking-wide">
        ¿Tu empresa enfrenta alguno de estos <span class="italic text-gold-bright">desafíos</span>?
      </h3>
      <div class="w-16 h-px bg-gold-deep/50 mx-auto shadow-[0_0_10px_rgba(136,192,208,0.8)]"></div>
    </div>

    <!-- Challenges Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto mb-16">
      
      <!-- Challenge 1 -->
      <div class="glass-card p-8 flex flex-col transition-all duration-300 rounded-none group">
        <!-- SVG Icon Excel -->
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-12 h-12 text-gold-deep mb-6 group-hover:text-gold-bright transition-colors" xmlns="http://www.w3.org/2000/svg">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <line x1="3" y1="9" x2="21" y2="9"/>
          <line x1="3" y1="15" x2="21" y2="15"/>
          <line x1="9" y1="9" x2="9" y2="21"/>
          <line x1="15" y1="9" x2="15" y2="21"/>
          <path d="M6 5h2v2H6z" fill="currentColor" fill-opacity="0.3" stroke="none"/>
          <path d="M12 5h2v2h-2z" fill="currentColor" fill-opacity="0.3" stroke="none"/>
        </svg>
        <p class="text-gray-300 font-montserrat font-light leading-relaxed text-base">
          Información dispersa en múltiples archivos Excel.
        </p>
      </div>

      <!-- Challenge 2 -->
      <div class="glass-card p-8 flex flex-col transition-all duration-300 rounded-none group">
        <!-- SVG Icon Manual Processes -->
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-12 h-12 text-gold-deep mb-6 group-hover:text-gold-bright transition-colors" xmlns="http://www.w3.org/2000/svg">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 6v6l4 2"/>
          <path d="M19 12a7 7 0 0 1-7 7" stroke-dasharray="2 2"/>
          <path d="M5 12a7 7 0 0 1 7-7" stroke-dasharray="2 2"/>
        </svg>
        <p class="text-gray-300 font-montserrat font-light leading-relaxed text-base">
          Procesos manuales que consumen tiempo.
        </p>
      </div>

      <!-- Challenge 3 -->
      <div class="glass-card p-8 flex flex-col transition-all duration-300 rounded-none group">
        <!-- SVG Icon Lack of Indicators -->
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-12 h-12 text-gold-deep mb-6 group-hover:text-gold-bright transition-colors" xmlns="http://www.w3.org/2000/svg">
          <path d="M3 3v18h18"/>
          <path d="M18.7 8l-5.1 5.2-2.8-2.7L7 14.3" stroke-dasharray="1 1"/>
          <circle cx="18.7" cy="8" r="2" fill="currentColor" fill-opacity="0.2" stroke="none"/>
          <path d="M12 7h2M12 11h5" stroke-dasharray="2 2"/>
        </svg>
        <p class="text-gray-300 font-montserrat font-light leading-relaxed text-base">
          Falta de indicadores para tomar decisiones.
        </p>
      </div>

      <!-- Challenge 4 -->
      <div class="glass-card p-8 flex flex-col transition-all duration-300 rounded-none group">
        <!-- SVG Icon Inventory Control -->
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-12 h-12 text-gold-deep mb-6 group-hover:text-gold-bright transition-colors" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2L3 7l9 5 9-5-9-5z"/>
          <path d="M3 7v10l9 5M21 7v10l-9 5"/>
          <path d="M12 12v10"/>
          <circle cx="12" cy="17" r="3" stroke-dasharray="2 2"/>
        </svg>
        <p class="text-gray-300 font-montserrat font-light leading-relaxed text-base">
          Dificultad para controlar ventas e inventarios.
        </p>
      </div>

      <!-- Challenge 5 -->
      <div class="glass-card p-8 flex flex-col transition-all duration-300 rounded-none group">
        <!-- SVG Icon Integration -->
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-12 h-12 text-gold-deep mb-6 group-hover:text-gold-bright transition-colors" xmlns="http://www.w3.org/2000/svg">
          <circle cx="6" cy="6" r="3"/>
          <circle cx="18" cy="6" r="3"/>
          <circle cx="12" cy="18" r="3"/>
          <line x1="9" y1="6" x2="15" y2="6" stroke-dasharray="2 2"/>
          <line x1="7.5" y1="8.5" x2="10.5" y2="15.5" stroke-dasharray="2 2"/>
          <line x1="16.5" y1="8.5" x2="13.5" y2="15.5" stroke-dasharray="2 2"/>
        </svg>
        <p class="text-gray-300 font-montserrat font-light leading-relaxed text-base">
          Escasa integración entre áreas.
        </p>
      </div>

      <!-- Challenge 6 -->
      <div class="glass-card p-8 flex flex-col transition-all duration-300 rounded-none group">
        <!-- SVG Icon Visibility -->
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-12 h-12 text-gold-deep mb-6 group-hover:text-gold-bright transition-colors" xmlns="http://www.w3.org/2000/svg">
          <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/>
          <circle cx="12" cy="12" r="3"/>
          <path d="M12 2v2M12 20v2" stroke-dasharray="2 2"/>
        </svg>
        <p class="text-gray-300 font-montserrat font-light leading-relaxed text-base">
          Poca visibilidad del desempeño del negocio.
        </p>
      </div>

    </div>

    <!-- CTA Section -->
    <div class="animate-on-scroll glass-card p-10 max-w-4xl mx-auto border-t-2 border-gold-bright text-center relative shadow-[0_0_30px_rgba(136,192,208,0.2)]">
      <div class="absolute top-0 inset-x-0 h-[2px] bg-gold-bright shadow-[0_0_15px_rgba(229,233,240,0.8)]"></div>
      
      <p class="text-xl md:text-2xl text-white font-montserrat font-normal tracking-wide mb-8 leading-relaxed max-w-3xl mx-auto">
        Pegasus Nexus convierte estos desafíos en <span class="italic text-gold-bright font-semibold text-glow">procesos digitales inteligentes</span>.
      </p>
      
      <a href="https://wa.me/59179786916?text=Hola%20Pegasus%20Nexus!%20Me%20gustar%C3%ADa%20solicitar%20un%20diagn%C3%B3stico%20para%20mi%20empresa%20y%20conocer%20c%C3%B3mo%20resolver%20nuestros%20desaf%C3%ADos." target="_blank" rel="noopener noreferrer" class="inline-block bg-transparent border border-gold-bright text-gold-bright hover:bg-gold-bright hover:text-cosmos-dark font-bold py-4 px-10 rounded-none transition-all text-xs tracking-widest uppercase shadow-[0_0_15px_rgba(229,233,240,0.2)] hover:scale-105 transform cursor-pointer">
        Solicitar Diagnóstico Gratuito
      </a>
    </div>
  </div>
</section>
