---
---
<footer class="bg-cosmos-light/50 border-t border-gold-deep/20 mt-20" id="contacto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center md:text-left">
      <div>
        <a href="/" class="flex items-center justify-center md:justify-start gap-2 mb-4 group">
          <div class="w-8 h-8 rounded-full border border-gold-deep flex items-center justify-center group-hover:shadow-[0_0_10px_rgba(212,175,55,0.6)]">
            <span class="text-gold-bright font-montserrat font-bold text-sm">PS</span>
          </div>
          <span class="text-lg font-black tracking-wider font-montserrat text-white uppercase">PEGASO<span class="text-gold-bright font-light">SYSTEM</span></span>
        </a>
        <p class="text-gray-400 text-sm leading-relaxed mb-6 font-montserrat font-light">
          Desarrollo de software comercial y aplicaciones web que elevan el cosmos de tu negocio con tecnología indestructible y veloz.
        </p>
      </div>

      <div>
        <h3 class="text-white font-bold font-heading text-lg mb-4 text-glow">Servicios</h3>
        <ul class="space-y-3">
          <li><a href="#servicios" class="text-gray-400 hover:text-gold-bright transition-colors">Seguridad (Tauro)</a></li>
          <li><a href="#servicios" class="text-gray-400 hover:text-gold-bright transition-colors">Backups (Fénix)</a></li>
          <li><a href="#servicios" class="text-gray-400 hover:text-gold-bright transition-colors">Integraciones API (Andrómeda)</a></li>
          <li><a href="#servicios" class="text-gray-400 hover:text-gold-bright transition-colors">SaaS (Pegaso)</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-white font-bold font-heading text-lg mb-4 text-glow">Contacto Corporativo</h3>
        <form class="space-y-4">
          <input type="email" placeholder="Tu correo electrónico" class="w-full bg-cosmos-dark/80 border border-gray-700 rounded px-4 py-2 text-white focus:outline-none focus:border-gold-bright focus:ring-1 focus:ring-gold-bright transition-all" />
          <button type="submit" class="w-full bg-gold-deep hover:bg-gold-bright text-cosmos-dark font-bold py-2 px-4 rounded transition-colors shadow-[0_0_10px_rgba(212,175,55,0.3)] hover:shadow-[0_0_15px_rgba(241,196,15,0.5)]">
            Enviar Mensaje
          </button>
        </form>
      </div>
    </div>

    <div class="border-t border-gray-800 mt-12 pt-8 flex flex-col md:flex-row justify-between items-center">
      <p class="text-gray-500 text-sm text-center md:text-left">
        &copy; {new Date().getFullYear()} Pegaso System. Todos los derechos reservados.
      </p>
      <div class="mt-4 md:mt-0">
        <p class="text-gray-600 text-xs tracking-widest uppercase">Ingeniería de Software de Clase Mundial</p>
      </div>
    </div>
  </div>
</footer>
